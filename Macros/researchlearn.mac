#event Success "You have fashioned the items together#*#"
#event FailedIt "You lacked the skills to fashion#*#"
#event CombineCant "You cannot combine these items#*#"
#event CombineMissing "You do not have all the components#*#"
#event CombineEmpty "You must place items#*#"

Sub Main(string ClassName, string SpellLevelArg, string TargetQtyArg)
/declare ClassNameOuter string outer
/varset ClassNameOuter ${ClassName}
/declare SectionName string outer
/declare SpellCount int outer
/declare SpellNum int outer
/declare SpellName string outer
/declare FailedSpells string outer
/declare FailCount int outer 0
/declare CurrentSpell string outer
/declare RetryNum int outer
/declare retrySpellNum int outer 0
/declare q int outer
/declare qLen int outer
/declare qStr string outer
/declare hasMissing int outer 0
/declare hasMissingSpecial int outer 0
/declare hasMissingFailed int outer 0
/declare hasMissingKlaz int outer 0
/declare hasMissingVori int outer 0
/declare CurrentLevel int outer
/declare TargetQty int outer 1
/declare SpellLevelArgOuter string outer
/declare kitPack int outer 10
/declare logToFile bool outer FALSE
/declare showDebug bool outer FALSE
/declare dropLevBeforeNav bool outer TRUE
/declare clearTempOnStart bool outer TRUE
/declare clearTempOnEnd bool outer TRUE
/declare parchLevelStart int outer 66
/declare parchLevelEnd int outer 70
/declare classCount int outer 12
/declare combineSucceeded bool outer FALSE
/declare combineFailed bool outer FALSE
/declare rlIniFile string outer researchlearn.ini
/declare rlLogFile string outer ../Config/ResearchLearn_log.txt
/declare parchVopwBatches int outer 0
/declare parchCleanserBatches int outer 0
/declare needKlazAfterParch int outer 0
/declare buyListItems string outer ""
/declare parchNeedFRV int outer 0
/declare parchNeedFV int outer 0
/declare parchNeedV int outer 0
/declare parchNeedRV int outer 0
/declare parchNeedFRP int outer 0
/declare singleSpellMode int outer 0
/declare singleSpellNum int outer 0
/declare singleSpellCopies int outer 0
/declare singleSpellClassHint string outer
/declare importBatchMode int outer 0
/declare fastMode bool outer TRUE

/call LoadSettings
/echo [ResearchLearn] macro ready (auto-open kit enabled)

/if (${ClassName.Upper.Equal[DOCTOR]}) {
	/call ResearchDoctor "${SpellLevelArg}"
	/return
}

/if (${ClassName.Length}==0) {
	/echo Usage: /mac researchlearn <class> <level|all> [quantity]
	/echo          /mac researchlearn "<spellname>" [quantity]
	/echo          /mac researchlearn doctor [class]
	/echo Examples: /mac researchlearn cleric 66
	/echo           /mac researchlearn cleric all 3
	/echo           /mac researchlearn "Panoply of Vie"
	/echo           /mac researchlearn "Panoply of Vie" 10
	/echo NOTE: Multi-word spell names require quotes!
	/return
}

/if (${clearTempOnStart} && !${ClassName.Upper.Equal[DOCTOR]}) {
	/call ClearBuyTempIni
}

| Lua/UI passes args via Config\ResearchLearn_pass.ini (macro params split on spaces)
/if (${ClassName.Equal[_spell]}) {
	/varset ClassName ${Ini[ResearchLearn_pass.ini,Pass,Name]}
	/declare rlPassCopies int local ${Ini[ResearchLearn_pass.ini,Pass,Copies]}
	/if (${rlPassCopies} > 0) /varset TargetQty ${rlPassCopies}
	/declare rlPassClass string local ${Ini[ResearchLearn_pass.ini,Pass,Class]}
	/if (${rlPassClass.Length} && !${rlPassClass.Equal[NULL]}) {
		/call NormalizeClassName ${rlPassClass}
		/varset singleSpellClassHint ${Macro.Return}
	}
	/varset SpellLevelArg
	/if (${ClassName.Length}==0 || ${ClassName.Equal[NULL]}) {
		/echo ERROR: _spell mode but Config\ResearchLearn_pass.ini is missing [Pass] Name=
		/return
	}
}
/if (${ClassName.Equal[_import]}) {
	/call RunImportBatch
	/echo === All done! ===
	/return
}
/if (${ClassName.Equal[_class]}) {
	/varset ClassName ${Ini[ResearchLearn_pass.ini,Pass,Class]}
	/varset SpellLevelArg ${Ini[ResearchLearn_pass.ini,Pass,Level]}
	/declare rlClassCopies int local ${Ini[ResearchLearn_pass.ini,Pass,Copies]}
	/if (${rlClassCopies} > 0) /varset TargetQty ${rlClassCopies}
	/varset TargetQtyArg
	/if (${ClassName.Length}==0 || ${ClassName.Equal[NULL]}) {
		/echo ERROR: _class mode but Config\ResearchLearn_pass.ini is missing [Pass] Class=
		/return
	}
	/if (${SpellLevelArg.Length}==0 || ${SpellLevelArg.Equal[NULL]}) /varset SpellLevelArg all
	/call NormalizeClassName ${ClassName}
	/varset ClassName ${Macro.Return}
	/varset ClassNameOuter ${ClassName}
	/varset SpellLevelArgOuter ${SpellLevelArg}
	/if (${SpellLevelArg.Equal[all]}) /goto :ClassLevelMode
	/declare rlClassLevel int local ${Int[${SpellLevelArg}]}
	/if (${rlClassLevel} >= 66 && ${rlClassLevel} <= 70) /goto :ClassLevelMode
	/echo ERROR: _class pass.ini has invalid Level=${SpellLevelArg} (use 66-70 or all)
	/return
}

| Rejoin unquoted multi-word spell names: Star + Scream -> Star Scream (qty shifts to SpellLevelArg)
:SpellRejoinLoop
/call IsKnownClass ${ClassName}
/if (${Macro.Return.Equal[TRUE]}) /goto :SpellRejoinDone
/if (${SpellLevelArg.Length}==0) /goto :SpellRejoinDone
/if (${SpellLevelArg.Equal[all]}) /goto :SpellRejoinDone
/if (${Int[${SpellLevelArg}]} > 0) /goto :SpellRejoinDone
/varset ClassName ${ClassName} ${SpellLevelArg}
/varset SpellLevelArg ${TargetQtyArg}
/varset TargetQtyArg
/goto :SpellRejoinLoop
:SpellRejoinDone

| Single spell mode vs class+level mode
| Class+level: /mac researchlearn enchanter 66  OR  enchanter all 3  OR  /mac researchlearn _class
| Single spell: /mac researchlearn "Fireskin"  OR  /mac researchlearn _spell
| ---------------------------------------------------------------
/call IsKnownClass ${ClassName}
/declare rlKnownClass int local 0
/if (${Macro.Return.Equal[TRUE]}) /varset rlKnownClass 1

/if (${rlKnownClass}) {
	/call NormalizeClassName ${ClassName}
	/varset ClassName ${Macro.Return}
	/varset ClassNameOuter ${ClassName}
	/if (${SpellLevelArg.Length}==0 || ${SpellLevelArg.Equal[NULL]}) {
		/echo \ayNote:\ax No level specified — defaulting to \agall\ax levels for ${ClassName}.
		/varset SpellLevelArg all
	}
	/if (${SpellLevelArg.Equal[all]}) /goto :ClassLevelMode
	/declare rlLevel int local ${Int[${SpellLevelArg}]}
	/if (${rlLevel} >= 66 && ${rlLevel} <= 70) /goto :ClassLevelMode
	/echo ERROR: Invalid level "${SpellLevelArg}" for class ${ClassName}. Use 66-70 or all.
	/return
}

| Not a class name — treat first arg as spell name
/if (${SpellLevelArg.Length}==0) {
	/call RunSingleSpell "${ClassName}"
	/echo === All done! ===
	/return
}
/if (${Int[${SpellLevelArg}]} > 0) {
	/varset TargetQty ${Int[${SpellLevelArg}]}
	/call RunSingleSpell "${ClassName}"
	/echo === All done! ===
	/return
}
/if (!${SpellLevelArg.Equal[all]}) {
	/declare testLevel int local ${Int[${SpellLevelArg}]}
	/if (${testLevel}==0) {
		/call RunSingleSpell "${ClassName}"
		/echo === All done! ===
		/return
	}
}

:ClassLevelMode
| Class+level mode — original two/three arg handling
/varset ClassNameOuter ${ClassName}
/varset SpellLevelArgOuter ${SpellLevelArg}
/if (${TargetQtyArg.Length} > 0 && ${Int[${TargetQtyArg}]} > 1) {
	/varset TargetQty ${Int[${TargetQtyArg}]}
}

/if (${SpellLevelArg.Length}==0) {
	/echo Usage: /mac researchlearn <class> <level|all> [quantity]
	/echo          /mac researchlearn <spellname> [quantity]
	/return
}

/if (${SpellLevelArg.Equal[all]}) {
	| Phase 0: Tally parchment needs, buy all vendor mats (merged Klaz), then craft parchments
	/echo === Checking parchment/vellum supply ===
	/call TallyParchmentNeeds
	/if (!${Macro.Return.Equal[TRUE]}) /end

	| Phase 1: Buy spell ingredients (+ merged Klaz parchment subcombine mats)
	/echo === Checking ingredients for all levels ===
	/call CheckAllLevelsMissing
	/call CheckAllLevelsVendors
	/if (${hasMissingKlaz}==1 || ${needKlazAfterParch}==1) {
		/call NavAndBuy "Scholar Klaz"
	} else {
		/echo Skipping Scholar Klaz - nothing needed from there.
	}
	/if (${hasMissingVori}==1) {
		/call NavAndBuy "Vori"
	} else {
		/echo Skipping Vori - nothing needed from there.
	}
	/if (${hasMissing}==0 && ${needKlazAfterParch}==0 && ${hasMissingVori}==0) {
		/echo All spell vendor ingredients already in inventory!
	}

	/call ExecuteParchmentPrep
	/if (!${Macro.Return.Equal[TRUE]}) /end

	| Phase 2: Combines for all levels
	/echo === Starting combines for all levels ===
	/call RequireResearchKit
	/varset FailedSpells
	/varset FailCount 0
	/varset CurrentLevel ${parchLevelStart}
	:CombineAllLoop
		/if (${CurrentLevel} > ${parchLevelEnd}) /goto :CombineAllDone
		/varset SectionName ${ClassName}_${CurrentLevel}
		/varset SpellCount ${Ini[${rlIniFile},${SectionName},SpellCount]}
		/if (${SpellCount} > 0) {
			/echo === Combining ${ClassName} level ${CurrentLevel} ===
			/call CombineLevel
		}
		/varcalc CurrentLevel ${CurrentLevel}+1
		/goto :CombineAllLoop
	:CombineAllDone

	| Phase 3: Retry all failures at the very end
	/if (${FailCount} > 0) {
		/echo === Retrying ${FailCount} failed spell(s) ===
		/call BuyForFailed
		/varset RetryNum 1
		:RetryAllLoop
			/if (${RetryNum} > ${FailCount}) /goto :RetryAllDone
			/varset SpellName ${FailedSpells.Arg[${RetryNum},,]}
			/call FindSpellSectionInClass ${ClassNameOuter} "${SpellName}"
			/if (${Macro.Return.Equal[TRUE]}) {
				/call DoSpell ${retrySpellNum} ${SpellName}
			} else {
				/echo WARNING: Could not find section for failed spell ${SpellName}
			}
			/varcalc RetryNum ${RetryNum}+1
			/goto :RetryAllLoop
		:RetryAllDone
	}
} else {
	/call RunLevel ${ClassName} ${SpellLevelArg}
}

/echo === Verifying all spells were made ===
/call VerifySpells
/if (${clearTempOnEnd}) {
	/call ClearBuyTempIni
}
/echo === All done! ===
/return

|====================================================================
| SETTINGS / LOGGING / DOCTOR
|====================================================================
Sub LoadSettings
/declare lsPack string local ${Ini[${rlIniFile},Settings,ResearchKitPack]}
/declare lsLog string local ${Ini[${rlIniFile},Settings,LogToFile]}
/declare lsDbg string local ${Ini[${rlIniFile},Settings,ShowDebug]}
/declare lsLev string local ${Ini[${rlIniFile},Settings,DropLevBeforeNav]}
/declare lsClrStart string local ${Ini[${rlIniFile},Settings,ClearTempIniOnStart]}
/declare lsClrEnd string local ${Ini[${rlIniFile},Settings,ClearTempIniOnEnd]}
/declare lsPStart string local ${Ini[${rlIniFile},Settings,ParchLevelStart]}
/declare lsPEnd string local ${Ini[${rlIniFile},Settings,ParchLevelEnd]}
/declare lsClassCount string local ${Ini[${rlIniFile},Classes,ClassCount]}
/declare lsFast string local ${Ini[${rlIniFile},Settings,FastMode]}

/if (${lsPack.Length} && ${Int[${lsPack}]} > 0) /varset kitPack ${Int[${lsPack}]}
/varset logToFile FALSE
/if (${lsLog.Equal[1]} || ${lsLog.Upper.Equal[ON]} || ${lsLog.Upper.Equal[TRUE]}) /varset logToFile TRUE
/varset showDebug FALSE
/if (${lsDbg.Equal[1]} || ${lsDbg.Upper.Equal[ON]} || ${lsDbg.Upper.Equal[TRUE]}) /varset showDebug TRUE
/varset fastMode TRUE
/if (${lsFast.Equal[0]} || ${lsFast.Upper.Equal[OFF]} || ${lsFast.Upper.Equal[FALSE]}) /varset fastMode FALSE
/varset dropLevBeforeNav TRUE
/if (${lsLev.Equal[0]} || ${lsLev.Upper.Equal[OFF]} || ${lsLev.Upper.Equal[FALSE]}) /varset dropLevBeforeNav FALSE
/varset clearTempOnStart TRUE
/if (${lsClrStart.Equal[0]} || ${lsClrStart.Upper.Equal[OFF]} || ${lsClrStart.Upper.Equal[FALSE]}) /varset clearTempOnStart FALSE
/varset clearTempOnEnd TRUE
/if (${lsClrEnd.Equal[0]} || ${lsClrEnd.Upper.Equal[OFF]} || ${lsClrEnd.Upper.Equal[FALSE]}) /varset clearTempOnEnd FALSE
/if (${lsPStart.Length} && ${Int[${lsPStart}]} > 0) /varset parchLevelStart ${Int[${lsPStart}]}
/if (${lsPEnd.Length} && ${Int[${lsPEnd}]} > 0) /varset parchLevelEnd ${Int[${lsPEnd}]}
/if (${lsClassCount.Length} && ${Int[${lsClassCount}]} > 0) /varset classCount ${Int[${lsClassCount}]}
/return

Sub LogDebug(string msg)
/if (!${showDebug} && !${logToFile}) /return
/if (${showDebug}) /echo \aw[RL DBG]\ax ${msg}
/if (${logToFile}) /squelch /mqlog [DEBUG] ${msg}
/return

Sub LogFail(string spellName, string reason)
/declare lfLine string local ${Time}|${Me.Name}|${ClassNameOuter}|${SpellLevelArgOuter}|${spellName}|${reason}
/if (${showDebug}) /echo \ar[RL FAIL]\ax ${spellName}: ${reason}
/if (${logToFile}) /squelch /mqlog [FAIL] ${lfLine}
/declare lfPath string local ${rlLogFile}
/squelch /ini ${lfPath} Log ${Time} "${lfLine}"
/return

Sub ClearBuyTempIni
/declare cbiLevel int local
/declare cbiSection string local
/declare cbiCount int local
/declare cbiSpell int local
/declare cbiIng int local
/declare cbiName string local
/declare cbiClass string local
/declare cbiClassNum int local
/declare cbiStart int local ${parchLevelStart}
/declare cbiEnd int local ${parchLevelEnd}

/if (${ClassNameOuter.Length} > 0) {
	/for cbiLevel ${cbiStart} to ${cbiEnd}
		/varset cbiSection ${ClassNameOuter}_${cbiLevel}
		/varset cbiCount ${Ini[${rlIniFile},${cbiSection},SpellCount]}
		/if (${cbiCount} > 0) /call ClearBuyTempIniForSection ${cbiSection} ${cbiCount}
	/next cbiLevel
} else {
	/for cbiClassNum 1 to ${classCount}
		/varset cbiClass ${Ini[${rlIniFile},Classes,Class${cbiClassNum}]}
		/if (${cbiClass.Length}==0 || ${cbiClass.Equal[NULL]}) /continue
		/for cbiLevel ${cbiStart} to ${cbiEnd}
			/varset cbiSection ${cbiClass}_${cbiLevel}
			/varset cbiCount ${Ini[${rlIniFile},${cbiSection},SpellCount]}
			/if (${cbiCount} > 0) /call ClearBuyTempIniForSection ${cbiSection} ${cbiCount}
		/next cbiLevel
	/next cbiClassNum
}
/varset buyListItems
/varset needKlazAfterParch 0
/return

Sub ClearBuyTempIniForSection(string sectionName, int spellTotal)
/declare ctsIng int local
/declare ctsName string local
/declare ctsSpell int local
/for ctsSpell 1 to ${spellTotal}
	/for ctsIng 1 to 20
		/varset ctsName ${Ini[${rlIniFile},${sectionName},Spell${ctsSpell}_Ingredient${ctsIng}]}
		/if (${ctsName.Length}==0 || ${ctsName.Equal[NULL]}) /break
		/ini MQ2MacroTemp.ini BuyCount "${ctsName}" NULL
		/ini MQ2MacroTemp.ini FailBuyCount "${ctsName}" NULL
	/next ctsIng
/next ctsSpell
/return

Sub ResearchDoctor(string classHint)
/declare rdTag string local \at[ResearchDoctor]\ax
/declare rdClass string local ${classHint}
/declare rdSection string local
/declare rdCount int local
/declare rdKitSlots int local ${Me.Inventory[pack${kitPack}].Container}

/echo ${rdTag} \au===== ResearchLearn Doctor =====\ax
/echo ${rdTag} \awChar:\ag ${Me.Name}\aw Class:\ag ${Me.Class.ShortName}\aw Zone:\at ${Zone.ShortName}\ax
/echo ${rdTag} \awINI:\ag ${rlIniFile}\aw exists=${If[${Ini.File[${rlIniFile}].Exists},\agYES,\arNO]}\ax
/echo ${rdTag} \awSettings: kitPack=\ag${kitPack}\aw logToFile=\ag${logToFile}\aw showDebug=\ag${showDebug}\ax
/echo ${rdTag} \awPP:\ag ${Me.Platinum}\aw Research kit slot pack${kitPack} slots=\ag${rdKitSlots}\ax

/call EnsureResearchKitOpen
/if (${Macro.Return.Equal[TRUE]}) {
	/echo ${rdTag} \agResearch kit combine window is open (Experiment mode).\ax
} else {
	/echo ${rdTag} \arResearch kit combine window is NOT open.\aw Could not auto-open kit.\ax
}

/if (${rdKitSlots} <= 0) {
	/echo ${rdTag} \arNo container in pack${kitPack}.\aw Set ResearchKitPack in INI or move kit to that bag slot.\ax
}

/if (${Zone.ShortName.NotEqual[poknowledge]}) {
	/echo ${rdTag} \ayWARNING:\aw PoK is recommended; current zone is ${Zone.ShortName}.
}

/if (${rdClass.Length}==0 || ${rdClass.Equal[NULL]}) /varset rdClass ${Me.Class.ShortName.Lower}
/call NormalizeClassName ${rdClass}
/varset rdClass ${Macro.Return}
/echo ${rdTag} \awINI class key:\ag ${rdClass}\aw (from ${Me.Class.ShortName})\ax
/varset rdSection ${rdClass}_66
/varset rdCount ${Ini[${rlIniFile},${rdSection},SpellCount]}
/if (${rdCount} > 0) {
	/echo ${rdTag} \agConfig OK:\aw [${rdSection}] has ${rdCount} spells.
} else {
	/echo ${rdTag} \arNo config for [${rdSection}].\aw Check class name and INI sections.\ax
}

/echo ${rdTag} \awBank dropped parchments (sample):\ax Sooty=${FindItemBankCount[=Sooty Fine Runic Vellum]} Grubby=${FindItemBankCount[=Grubby Fine Vellum]} Dirty=${FindItemBankCount[=Dirty Vellum]}
/echo ${rdTag} \awClasses in INI:\ag ${classCount}\aw  Run:\at /mac researchlearn <class> all\ax
/return

|====================================================================
| CONFIG LOOKUP
|====================================================================
Sub IngredientNeedQty(string section, int spellNum, string ingName, int copiesNeeded)
/declare inqCount int local 0
/declare inqIng int local
/declare inqSlotName string local
/for inqIng 1 to 20
	/varset inqSlotName ${Ini[${rlIniFile},${section},Spell${spellNum}_Ingredient${inqIng}]}
	/if (${inqSlotName.Length}==0 || ${inqSlotName.Equal[NULL]}) /break
	/if (${inqSlotName.Equal[${ingName}]}) /varcalc inqCount ${inqCount}+1
/next inqIng
/return ${Math.Calc[${inqCount}*${copiesNeeded}]}

Sub IsKnownClassDirect(string name)
/declare ikIdx int local
/declare ikCls string local
/varset name ${name.Lower}
/for ikIdx 1 to ${classCount}
	/varset ikCls ${Ini[${rlIniFile},Classes,Class${ikIdx}].Lower}
	/if (${ikCls.Length}==0 || ${ikCls.Equal[NULL]}) /continue
	/if (${ikCls.Equal[${name}]}) /return TRUE
/next ikIdx
/return FALSE

Sub NormalizeClassName(string raw)
/declare nc string local ${raw.Lower}
/call IsKnownClassDirect ${nc}
/if (${Macro.Return.Equal[TRUE]}) /return ${nc}
/if (${nc.Equal[mag]}) /varset nc magician
/if (${nc.Equal[mage]}) /varset nc magician
/if (${nc.Equal[clr]}) /varset nc cleric
/if (${nc.Equal[bst]}) /varset nc beastlord
/if (${nc.Equal[ber]}) /varset nc berserker
/if (${nc.Equal[brd]}) /varset nc bard
/if (${nc.Equal[dru]}) /varset nc druid
/if (${nc.Equal[enc]}) /varset nc enchanter
/if (${nc.Equal[mnk]}) /varset nc monk
/if (${nc.Equal[nec]}) /varset nc necromancer
/if (${nc.Equal[pal]}) /varset nc paladin
/if (${nc.Equal[rng]}) /varset nc ranger
/if (${nc.Equal[rog]}) /varset nc rogue
/if (${nc.Equal[shd]}) /varset nc shadowknight
/if (${nc.Equal[shm]}) /varset nc shaman
/if (${nc.Equal[wiz]}) /varset nc wizard
/if (${nc.Equal[war]}) /varset nc warrior
/call IsKnownClassDirect ${nc}
/if (${Macro.Return.Equal[TRUE]}) /return ${nc}
/return ${nc}

Sub IsKnownClass(string name)
/call NormalizeClassName ${name}
/call IsKnownClassDirect ${Macro.Return}
/return

Sub FindSpellSectionInClass(string className, string spellName)
/declare fscLevel int local
/declare fscSection string local
/declare fscCount int local
/declare fscNum int local
/declare fscName string local
/declare snLower string local ${spellName.Lower}
/varset className ${className.Lower}
/varset retrySpellNum 0
/for fscLevel ${parchLevelStart} to ${parchLevelEnd}
	/varset fscSection ${className}_${fscLevel}
	/varset fscCount ${Ini[${rlIniFile},${fscSection},SpellCount]}
	/if (${fscCount} <= 0) /continue
	/for fscNum 1 to ${fscCount}
		/varset fscName ${Ini[${rlIniFile},${fscSection},Spell${fscNum}]}
		/if (${fscName.Lower.Equal[${snLower}]} || ${fscName.Lower.Equal[spell: ${snLower}]} || ${fscName.Lower.Equal[skill: ${snLower}]} || ${fscName.Lower.Equal[tome of ${snLower}]} || ${fscName.Lower.Equal[tome of ${snLower} rk. ii]}) {
			/varset SectionName ${fscSection}
			/varset SpellCount ${fscCount}
			/varset retrySpellNum ${fscNum}
			/varset SpellName ${fscName}
			/return TRUE
		}
	/next fscNum
/next fscLevel
/return FALSE

| Prefer the class recorded in ResearchLearn_pass.ini (avoids wrong-class recipe for
| duplicate spell names like Placate / Desolate Undead / Elemental Fury)
Sub FindSpellForImport(int ribIdx, string itemName)
/declare fsiClass string local ${Ini[ResearchLearn_pass.ini,Pass,Class${ribIdx}]}
/if (${fsiClass.Length} && !${fsiClass.Equal[NULL]}) {
	/call NormalizeClassName ${fsiClass}
	/call FindSpellSectionInClass ${Macro.Return} "${itemName}"
	/if (${Macro.Return.Equal[TRUE]}) /return TRUE
}
/call FindSpellSectionAny "${itemName}"
/return ${Macro.Return}

Sub FindSpellSectionAny(string spellName)
/declare fsaClassNum int local
/declare fsaClass string local
/for fsaClassNum 1 to ${classCount}
	/varset fsaClass ${Ini[${rlIniFile},Classes,Class${fsaClassNum}]}
	/if (${fsaClass.Length}==0 || ${fsaClass.Equal[NULL]}) /continue
	/call FindSpellSectionInClass ${fsaClass} "${spellName}"
	/if (${Macro.Return.Equal[TRUE]}) /return TRUE
/next fsaClassNum
/return FALSE

Sub IsParchmentIngredient(string itemName)
/if (${itemName.Equal[Fine Runic Vellum]}) /return TRUE
/if (${itemName.Equal[Fine Vellum]}) /return TRUE
/if (${itemName.Equal[Vellum]}) /return TRUE
/if (${itemName.Equal[Runic Vellum]}) /return TRUE
/if (${itemName.Equal[Fine Runic Parchment]}) /return TRUE
/return FALSE

|====================================================================
| CURSOR / QUANTITY / KIT HELPERS (TurboGive/TurboLoot patterns)
|====================================================================
Sub SetQuantityWndValue(int desired)
/if (!${Window[QuantityWnd].Open}) /return
/if (${desired} <= 0) /return
/declare sqvDesiredStr string local ${desired}
/declare sqvClearTry int local 0
/declare sqvCurLen int local
/declare sqvI int local
/squelch /invoke ${Window[QuantityWnd].Child[QTYW_SliderInput].SetText[${sqvDesiredStr}]}
/delay 3 ${Window[QuantityWnd].Child[QTYW_SliderInput].Text.Equal[${sqvDesiredStr}]}
/if (${Window[QuantityWnd].Child[QTYW_SliderInput].Text.Equal[${sqvDesiredStr}]}) /return
/notify QuantityWnd QTYW_Slider newvalue ${desired}
/delay 5
/if (${Window[QuantityWnd].Child[QTYW_SliderInput].Text.Equal[${sqvDesiredStr}]}) /return
/notify QuantityWnd QTYW_SliderInput newvalue ${desired}
/delay 5
/if (${Window[QuantityWnd].Child[QTYW_SliderInput].Text.Equal[${sqvDesiredStr}]}) /return
:sqvClearLoop
/varset sqvCurLen ${Window[QuantityWnd].Child[QTYW_SliderInput].Text.Length}
/if (${sqvCurLen} <= 0) /goto :sqvTypeValue
/nomodkey /keypress backspace chat
/delay 2 ${Window[QuantityWnd].Child[QTYW_SliderInput].Text.Length} < ${sqvCurLen}
/varcalc sqvClearTry ${sqvClearTry}+1
/if (${sqvClearTry} > 20) /goto :sqvTypeValue
/goto :sqvClearLoop
:sqvTypeValue
/for sqvI 1 to ${sqvDesiredStr.Length}
	/nomodkey /keypress ${sqvDesiredStr.Mid[${sqvI},1]} chat
	/delay 2
/next sqvI
/delay 2
/return

Sub DismissQuantityWindow
/declare dqwTry int local 0
/if (!${Window[QuantityWnd].Open}) /return
/for dqwTry 1 to 4
	/if (!${Window[QuantityWnd].Open}) /return
	/squelch /notify QuantityWnd QTYW_Cancel_Button leftmouseup
	/delay 5 !${Window[QuantityWnd].Open}
	/if (!${Window[QuantityWnd].Open}) /return
	/squelch /notify QuantityWnd CancelButton leftmouseup
	/delay 5 !${Window[QuantityWnd].Open}
/next dqwTry
/if (${Window[QuantityWnd].Open}) {
	/keypress esc
	/delay 5 !${Window[QuantityWnd].Open}
}
/if (${Window[QuantityWnd].Open}) /call HandleQuantityWindow
/return

| Radix-style: wait for qty window, set amount, accept, wait for close
Sub ConfirmMerchantBuyQuantity(int desiredQty)
/declare cmqWait int local 0
/declare cmqTry int local 0
/declare cmqDesiredStr string local
/if (${desiredQty} <= 0) /varset desiredQty 1
/varset cmqDesiredStr ${desiredQty}
/for cmqWait 1 to 30
	/if (${Window[QuantityWnd].Open}) /goto :CmqSetQty
	/delay 5
/next cmqWait
/if (!${Window[QuantityWnd].Open}) /return FALSE
:CmqSetQty
/for cmqTry 1 to 3
	/call SetQuantityWndValue ${desiredQty}
	/delay 10 ${Window[QuantityWnd].Child[QTYW_SliderInput].Text.Equal[${cmqDesiredStr}]}
	/nomodkey /notify QuantityWnd QTYW_Accept_Button leftmouseup
	/delay 20 !${Window[QuantityWnd].Open}
	/if (!${Window[QuantityWnd].Open}) /return TRUE
	/delay 5
/next cmqTry
/call DismissQuantityWindow
/return FALSE

Sub HandleQuantityWindow
/if (!${Window[QuantityWnd].Open}) /return
/squelch /notify QuantityWnd AcceptButton leftmouseup
/squelch /notify QuantityWnd QTYW_Accept_Button leftmouseup
/keypress ENTER
/delay 10 !${Window[QuantityWnd].Open}
/delay 1
/if (${Window[QuantityWnd].Open}) /call DismissQuantityWindow
/if (${Cursor.ID}) {
	/delay 5 !${Cursor.ID}
	/if (${Cursor.ID}) /call ForceClearCursor
}
/return

Sub WaitForCursor(int maxMs)
| FIX: /delay units are tenths of a second - convert ms to ds (was waiting up to 25-50s on failures)
/declare wfcMs int local ${maxMs}
/declare wfcDs int local 1
/if (${wfcMs} <= 0) /varset wfcMs 100
/if (${fastMode} && ${wfcMs} > 250) /varset wfcMs 250
/varcalc wfcDs (${wfcMs}+99)/100
/if (${wfcDs} < 1) /varset wfcDs 1
/delay ${wfcDs} ${Cursor.ID}
/return

Sub WaitForEmptyCursor(int maxMs)
| FIX: /delay units are tenths of a second - convert ms to ds
/declare wecMs int local ${maxMs}
/declare wecDs int local 1
/if (${wecMs} <= 0) /varset wecMs 100
/if (${fastMode} && ${wecMs} > 250) /varset wecMs 250
/varcalc wecDs (${wecMs}+99)/100
/if (${wecDs} < 1) /varset wecDs 1
/delay ${wecDs} !${Cursor.ID}
/return

Sub QuickGrabDrop(string itemName, int slotNum)
| Fast kit placement for parchment subcombines
/call GuardResearchKit
/nomodkey /ctrlkey /itemnotify "${itemName}" leftmouseup
/call WaitForCursor 250
/if (${Window[QuantityWnd].Open}) /call ConfirmMerchantBuyQuantity 1
/if (${Cursor.ID}) /call DropIntoKitSlot ${slotNum}
/return

Sub ForceClearCursor
/declare clearTries int local 0
/while (${Cursor.ID} && ${clearTries} < 5) {
	/varcalc clearTries ${clearTries}+1
	/if (${showDebug}) /call LogDebug "Clearing cursor: ${Cursor.Name} (attempt ${clearTries})"
	/autoinventory
	/call WaitForEmptyCursor 100
	/if (${Cursor.ID}) {
		/autoi
		/call WaitForEmptyCursor 100
	}
}
/return

Sub ClearCursorFast
:CursorLoop
/if (${Cursor.ID}) {
	/autoinv
	/delay 4 !${Cursor.ID}
	/goto :CursorLoop
}
/return

Sub CloseBlockingWindows
/if (${Window[MerchantWnd].Open}) {
	/notify MerchantWnd MW_Done_Button leftmouseup
	/delay 10 !${Window[MerchantWnd].Open}
	/if (${Window[MerchantWnd].Open}) /notify MerchantWnd DoneButton leftmouseup
	/delay 10 !${Window[MerchantWnd].Open}
}
/if (${Window[BigBankWnd].Open}) {
	/notify BigBankWnd DoneButton leftmouseup
	/delay 10 !${Window[BigBankWnd].Open}
}
/return

Sub KitSlotItemName(int slotNum)
| Spell Research Kit = container in top-level pack${kitPack} (NOT enviro — enviro is forge/kiln only)
/declare ksin string local ${Me.Inventory[pack${kitPack}].Item[${slotNum}].Name}
/if (${ksin.Length}==0 || ${ksin.Equal[NULL]}) /return NULL
/return ${ksin}

Sub KitSlotHasItem(int slotNum, string itemName)
/declare khn string local ${Me.Inventory[pack${kitPack}].Item[${slotNum}].Name}
/if (${khn.Length}==0 || ${khn.Equal[NULL]}) /return FALSE
/if (${khn.Equal[${itemName}]}) /return TRUE
/if (${khn.Find[${itemName}]}) /return TRUE
/return FALSE

| Count in bags + stacks sitting in open research kit (FindItemCount misses kit contents)
Sub CountItemEverywhere(string itemName)
/declare cieTotal int local ${FindItemCount[=${itemName}]}
/declare cieSlot int local 1
/declare cieName string local
/declare cieStack int local
/if (!${Window[ContainerCombine_Items].Open}) /return ${cieTotal}
/for cieSlot 1 to 10
	/call KitSlotItemName ${cieSlot}
	/varset cieName ${Macro.Return}
	/if (${cieName.Length}==0 || ${cieName.Equal[NULL]}) /continue
	/if (${cieName.Equal[${itemName}]} || ${cieName.Find[${itemName}]}) {
		/varset cieStack ${Me.Inventory[pack${kitPack}].Item[${cieSlot}].Stack}
		/if (${cieStack} <= 0) /varset cieStack 1
		/varcalc cieTotal ${cieTotal}+${cieStack}
	}
/next cieSlot
/return ${cieTotal}

Sub PickUpOneItem(string itemName)
| Same pattern as MakeVialOfPureWater (ctrlkey name) + pack/InvSlot fallbacks
/declare pikMethod int local 0
/declare pikPack int local ${FindItem[=${itemName}].ItemSlot}
/declare pikSlot int local ${FindItem[=${itemName}].ItemSlot2}
/declare pikInv int local ${FindItem[=${itemName}].InvSlot}
/declare pikPackNum int local 0
/declare pikSlotNum int local 0

/if (${Cursor.ID}) /call ForceClearCursor
/if (!${FindItemCount[=${itemName}]}) /return FALSE

/for pikMethod 1 to 3
	/if (${pikMethod}==1) {
		/nomodkey /ctrlkey /itemnotify "${itemName}" leftmouseup
	} else /if (${pikMethod}==2) {
		/if (${pikPack} < 23 || ${pikPack} > 32 || ${pikSlot} < 0) /continue
		/varcalc pikPackNum ${pikPack}-22
		/varcalc pikSlotNum ${pikSlot}+1
		/nomodkey /ctrl /itemnotify in pack${pikPackNum} ${pikSlotNum} leftmouseup
	} else {
		/if (${pikInv} <= 0) /continue
		/nomodkey /ctrl /itemnotify ${pikInv} leftmouseup
	}
	/call WaitForCursor 500
	/call AcceptQuantityPickup 1
	/call WaitForCursor 500
	/if (${Cursor.ID}) {
		/if (${Cursor.Name.Equal[${itemName}]} || ${Cursor.Name.Find[${itemName}]}) /return TRUE
		/if (${showDebug}) /echo DEBUG: Pickup ${itemName} method ${pikMethod} got cursor ${Cursor.Name}
		/call ForceClearCursor
	}
/next pikMethod
/return FALSE

Sub DropIntoKitSlot(int slotNum)
| Container slots: in pack${kitPack} 1-10 (radix pack-container pattern, not enviro)
/if (!${Cursor.ID}) /return FALSE
/nomodkey /itemnotify in pack${kitPack} ${slotNum} leftmouseup
/call WaitForEmptyCursor 500
/return TRUE

Sub EnsureResearchKitOpen
| Opens Spell Research Kit and switches to Experiment mode if needed
/call CloseBlockingWindows
/if (${Cursor.ID}) /call ForceClearCursor
/if (${Window[ContainerCombine_Items].Open}) /return TRUE

/if (!${FindItemCount[=Spell Research Kit]}) {
	/echo ERROR: Spell Research Kit not found in inventory!
	/return FALSE
}

/declare erkSlot int local ${FindItem[=Spell Research Kit].ItemSlot}
/declare erkSlot2 int local ${FindItem[=Spell Research Kit].ItemSlot2}
/declare erkWait int local 0
/declare erkTry int local 0

/if (${erkSlot2} != -1) {
	/echo ERROR: Move Spell Research Kit to a top-level bag slot (not inside another bag).
	/echo Set ResearchKitPack in researchlearn.ini to that slot number (default 10).
	/return FALSE
}

/if (${erkSlot} >= 23 && ${erkSlot} <= 32) {
	/varset kitPack ${Math.Calc[${erkSlot}-22]}
}

/for erkTry 1 to 4
	/if (${Window[ContainerCombine_Items].Open}) /return TRUE

	| Inventory open helps pack right-click register
	/if (!${Window[InventoryWindow].Open}) {
		/keypress i
		/delay 5 ${Window[InventoryWindow].Open}
	}

	/if (${erkSlot} >= 23 && ${erkSlot} <= 32) {
		/nomodkey /itemnotify pack${kitPack} rightmouseup
	} else {
		/nomodkey /itemnotify "Spell Research Kit" rightmouseup
	}
	/delay 10

	/if (${Window[TradeskillWnd].Open}) {
		/nomodkey /notify TradeskillWnd COMBW_ExperimentButton leftmouseup
		/delay 10
	}

	/if (!${Window[ContainerCombine_Items].Open}) {
		/squelch /combine pack${kitPack}
		/delay 10
	}

	/if (${Window[TradeskillWnd].Open} && !${Window[ContainerCombine_Items].Open}) {
		/nomodkey /notify TradeskillWnd COMBW_ExperimentButton leftmouseup
		/delay 10
	}

	/varset erkWait 0
	:ErkWaitCombine
		/if (${Window[ContainerCombine_Items].Open}) /goto :ErkOpenDone
		/varcalc erkWait ${erkWait}+1
		/if (${erkWait} >= 24) /goto :ErkWaitGiveUp
		/delay 5
		/goto :ErkWaitCombine
	:ErkWaitGiveUp
/next erkTry

:ErkOpenFailed
/echo ERROR: Could not open Spell Research Kit in Experiment mode (pack${kitPack}).
/echo Try: move kit to top-level bag slot ${kitPack}, close vendor windows, right-click kit once manually.
/return FALSE

:ErkOpenDone
/if (${showDebug}) /call LogDebug "Research kit open in Experiment mode (pack${kitPack})"
/return TRUE

| Reopen kit if it closed mid-macro (vendor/bag clicks can close container window)
Sub GuardResearchKit
/if (${Window[ContainerCombine_Items].Open}) /return TRUE
/if (${showDebug}) /echo DEBUG: Research kit closed — reopening...
/call EnsureResearchKitOpen
/return ${Macro.Return}

Sub RequireResearchKit
/declare rrkTry int local 0
/for rrkTry 1 to 3
	/call EnsureResearchKitOpen
	/if (${Macro.Return.Equal[TRUE]}) /return
	/delay 10
	/call CloseBlockingWindows
/next rrkTry
/echo ERROR: Could not open Spell Research Kit in Experiment mode after 3 attempts.
/end

Sub ClearResearchKit
/declare crkSlot int local 1
/if (!${Window[ContainerCombine_Items].Open}) /return
:CrkClearLoop
	/if (${crkSlot} > 10) /return
	/call KitSlotItemName ${crkSlot}
	/if (${Macro.Return.Length} > 0 && !${Macro.Return.Equal[NULL]}) {
		/nomodkey /itemnotify in pack${kitPack} ${crkSlot} leftmouseup
		/call WaitForCursor 100
		/if (${Window[QuantityWnd].Open}) /call HandleQuantityWindow
		/if (${Cursor.ID}) /autoinv
		/call WaitForEmptyCursor 100
	}
	/varcalc crkSlot ${crkSlot}+1
	/goto :CrkClearLoop
/return

Sub PlaceItemInKit(string itemName, int slotNum)
/declare pikTry int local 0

/if (!${itemName.Length} || ${itemName.Equal[NULL]}) /return FALSE
/if (!${FindItemCount[=${itemName}]}) /return FALSE
/call EnsureResearchKitOpen
/if (!${Macro.Return.Equal[TRUE]}) /return FALSE
/if (!${Window[ContainerCombine_Items].Open}) /return FALSE
/call CloseBlockingWindows
/if (${Cursor.ID}) /call ForceClearCursor

/if (!${Window[InventoryWindow].Open}) {
	/keypress i
	/delay 5 ${Window[InventoryWindow].Open}
}
/keypress OPEN_INV_BAGS
/delay 5

/call KitSlotHasItem ${slotNum} "${itemName}"
/if (${Macro.Return.Equal[TRUE]}) /return TRUE

/for pikTry 1 to 5
	/if (${Cursor.ID}) /call ForceClearCursor
	/call PickUpOneItem "${itemName}"
	/if (!${Macro.Return.Equal[TRUE]}) /continue
	/call DropIntoKitSlot ${slotNum}
	| Empty cursor after drop into pack container = placed
	/if (!${Cursor.ID}) /return TRUE
	/call KitSlotHasItem ${slotNum} "${itemName}"
	/if (${Macro.Return.Equal[TRUE]}) /return TRUE
/next pikTry
/echo \arPickup failed:\ax ${itemName} (have ${FindItemCount[=${itemName}]}, ItemSlot=${FindItem[=${itemName}].ItemSlot} slot2=${FindItem[=${itemName}].ItemSlot2}) — open bags (i), close merchant.
/return FALSE

Sub DoKitCombine
/call GuardResearchKit
| Spell Research Kit: ContainerCombine button, or /combine packN for open container
/if (${Window[ContainerCombine_Items].Open}) {
	/notify ContainerCombine_Items Container_Combine leftmouseup
} else {
	/squelch /combine pack${kitPack}
}
/return

|====================================================================
| NAVIGATION (TurboLoot NavToIDWithDoorsAndNudges pattern)
|====================================================================
Sub ScrollHaveCount(string scrollName)
/declare shcCount int local ${FindItemCount[=${scrollName}]}
/if (${shcCount} > 0) /return ${shcCount}
/if (${scrollName.Find[Spell:]}) /return ${shcCount}
/varset shcCount ${FindItemCount[=Spell: ${scrollName}]}
/return ${shcCount}

Sub CursorMatchesScroll(string scrollName)
/if (!${Cursor.ID}) /return FALSE
/if (${Cursor.Name.Equal[${scrollName}]}) /return TRUE
/if (${Cursor.Name.Find[${scrollName}]}) /return TRUE
/return FALSE

Sub WaitForSpellCombine(string scrollName, int haveBefore)
/declare wscWait int local 0
/declare wscHave int local 0
/varset combineSucceeded FALSE
/varset combineFailed FALSE
/for wscWait 1 to 40
	/delay 5
	/doevents
	/if (${combineFailed}) /return FALSE
	/if (${combineSucceeded}) /return TRUE
	/call CursorMatchesScroll "${scrollName}"
	/if (${Macro.Return.Equal[TRUE]}) /return TRUE
	/call ScrollHaveCount "${scrollName}"
	/varset wscHave ${Macro.Return}
	/if (${wscHave} > ${haveBefore}) /return TRUE
/next wscWait
/doevents
/if (${combineFailed}) /return FALSE
/if (${combineSucceeded}) /return TRUE
/call CursorMatchesScroll "${scrollName}"
/if (${Macro.Return.Equal[TRUE]}) /return TRUE
/call ScrollHaveCount "${scrollName}"
/if (${Macro.Return} > ${haveBefore}) /return TRUE
/return FALSE

Sub DumpKitSlots
/declare dks int local 1
/declare dksName string local
/declare dksFilled int local 0
/for dks 1 to 10
	/call KitSlotItemName ${dks}
	/varset dksName ${Macro.Return}
	/if (${dksName.Length} > 0 && !${dksName.Equal[NULL]}) {
		/varcalc dksFilled ${dksFilled}+1
		/echo   slot ${dks}: ${dksName}
	}
/next dks
/if (${dksFilled} > 0) {
	/echo   kit pack${kitPack}: ${dksFilled}/10 slots filled
} else {
	/echo   kit pack${kitPack}: (empty or container closed)
}
/return

Sub TryOpenNearbyDoor(int radius)
/declare r int local ${radius}
/if (${r} <= 0) /varset r 35
/if (${SpawnCount[door radius ${r}]} == 0) /return FALSE
/doortarget
/delay 2
/if (${DoorTarget.ID}) {
	/click left door
	/delay 10
	/return TRUE
}
/return FALSE

Sub StopNav
/squelch /nav stop
/delay 3
/squelch /nav stop
/return

| Four varied nudge patterns per stuck recovery (forward/back + strafe alternation)
Sub NavNudgeBurst(int targetID, float stopDist)
/declare tid int local ${targetID}
/declare distGoal float local ${stopDist}
/declare startDist float local ${Target.Distance}
/declare n int local
/for n 1 to 4
	/if (!${Target.ID} || ${Target.ID} != ${tid}) /return
	/if (${Target.Distance} <= ${distGoal}) /return
	/call StopNav
	/call TryOpenNearbyDoor 40
	/face fast
	/delay 1
	/if (${n} == 3) {
		/keypress back hold
		/delay 2
		/keypress back
		/delay 5
	} else {
		/keypress forward hold
		/delay 3
		/keypress forward
	}
	/if (${Math.Calc[${n}%2]} == 1) {
		/keypress strafe_left hold
		/delay 2
		/keypress strafe_left
	} else {
		/keypress strafe_right hold
		/delay 2
		/keypress strafe_right
	}
	/call StopNav
	/if (${Target.Distance} <= ${distGoal}) /return
	/if (${Math.Abs[${startDist}-${Target.Distance}]} >= 3) /return
/next n
/return

Sub NavToIDWithDoorsAndNudges(int targetID, float stopDist, int maxTicks)
/declare tid int local ${targetID}
/declare distGoal float local ${stopDist}
/declare limit int local ${maxTicks}
/declare navTicks int local 0
/declare lastDist float local 999999
/declare stuckCount int local 0
/declare stuckBursts int local 0
/declare lastX float local ${Me.X}
/declare lastY float local ${Me.Y}
/call StopNav
/if (${Navigation.PathExists[id ${tid}]}) {
	/nav id ${tid} distance=${distGoal}
} else {
	/nav id ${tid} distance=${distGoal}
}
:NavIDLoop
/doevents
/delay 1
/varcalc navTicks ${navTicks}+1
/if (!${Target.ID} || ${Target.ID} != ${tid}) {
	/call StopNav
	/return
}
/if (${Target.Distance} <= ${distGoal}) {
	/call StopNav
	/return
}
/if (${Math.Abs[${Target.Distance}-${lastDist}]} < 0.5 && ${Math.Abs[${Me.X}-${lastX}]} < 0.5 && ${Math.Abs[${Me.Y}-${lastY}]} < 0.5) {
	/varcalc stuckCount ${stuckCount}+1
} else {
	/varset stuckCount 0
	/varset stuckBursts 0
}
/varset lastDist ${Target.Distance}
/varset lastX ${Me.X}
/varset lastY ${Me.Y}
/if (!${Navigation.Active} && ${Target.Distance} > (${distGoal}+2)) {
	/nav id ${tid} distance=${distGoal}
}
/if (${stuckCount} >= 30) {
	/varcalc stuckBursts ${stuckBursts}+1
	/echo [researchlearn] Nav stuck (${Target.CleanName}, ${Target.Distance} ft) - nudge burst ${stuckBursts}/3...
	/if (${showDebug} || ${logToFile}) /call LogDebug "Nav stuck dist=${Target.Distance} burst=${stuckBursts}"
	/call StopNav
	/call NavNudgeBurst ${tid} ${distGoal}
	/call StopNav
	/varset stuckCount 0
	/if (${stuckBursts} >= 3 && ${Target.Distance} > (${distGoal}+5)) {
		/echo [researchlearn] Nav gave up after 3 nudge bursts - still ${Target.Distance} ft from ${Target.CleanName}
		/call StopNav
		/return
	}
	/nav id ${tid} distance=${distGoal}
}
/if (${Math.Calc[${navTicks}%20]} == 0) /call TryOpenNearbyDoor 40
/if (${navTicks} >= ${limit}) {
	/echo [researchlearn] Nav timed out - /nav stop (${Target.CleanName}, ${Target.Distance} ft)
	/call StopNav
	/return
}
/goto :NavIDLoop

Sub NavToSpawn(string spawnName)
/declare nssLevSetting string local ${Ini[${rlIniFile},Settings,DropLevBeforeNav]}
/declare navStopDist float local 10
/if (${dropLevBeforeNav} && ${Me.Levitating}) {
	/removelev
	/delay 10 !${Me.Levitating}
}
/echo Navigating to ${spawnName}...
/target ${spawnName}
/delay 10 ${Target.ID}
/if (!${Target.ID}) {
	/echo Could not find ${spawnName}!
	/return FALSE
}
/if (${Target.Distance} > ${navStopDist}) {
	/call NavToIDWithDoorsAndNudges ${Target.ID} ${navStopDist} 900
}
/if (!${Target.ID}) {
	/target ${spawnName}
	/delay 10 ${Target.ID}
}
/if (!${Target.ID}) {
	/echo Lost target ${spawnName} during navigation!
	/return FALSE
}
/if (${Target.Distance} > (${navStopDist}+5)) {
	/echo WARNING: Still ${Target.Distance} from ${spawnName} after nav - moveto fallback...
	/declare nssTries int local 0
	/declare nssID int local ${Target.ID}
	:NavMovetoLoop
		/if (!${Target.ID} || ${Target.ID} != ${nssID}) {
			/target id ${nssID}
			/delay 5 ${Target.ID}
		}
		/if (${Target.Distance} <= (${navStopDist}+2)) /goto :NavMovetoDone
		/varcalc nssTries ${nssTries}+1
		/if (${nssTries} > 40) /goto :NavMovetoDone
		/face fast
		/moveto id ${nssID} dist ${navStopDist}
		/delay 5
		/doevents
		/goto :NavMovetoLoop
	:NavMovetoDone
}
/face fast
/delay 1
/return TRUE

Sub WaitForMerchantList
/declare wmlWait int local 0
:WmlLoop
/if (${Window[MW_PurchasePage].Child[MW_ItemList].Items} > 0) /return TRUE
/varcalc wmlWait ${wmlWait}+1
/if (${wmlWait} >= 40) /return FALSE
/delay 5
/goto :WmlLoop

Sub OpenTargetMerchant
/declare otmTry int local 0
/if (!${Target.ID}) /return FALSE
/face fast
/delay 1
/for otmTry 1 to 3
	/if (${Target.Distance} <= 12) {
		/invoke ${Merchant.OpenWindow}
		/delay 100 ${Window[MerchantWnd].Open}
		/doevents
	}
	/if (!${Window[MerchantWnd].Open}) {
		/click right target
		/delay 100 ${Window[MerchantWnd].Open}
		/doevents
	}
	/if (${Window[MerchantWnd].Open}) {
		/call WaitForMerchantList
		/return TRUE
	}
	/face fast
	/keypress forward hold
	/delay 5
	/keypress forward
	/delay 2
/next otmTry
/echo Could not open vendor window for ${Target.CleanName}!
/return FALSE

Sub RegisterBuyListItem(string itemName)
/if (${itemName.Length}==0 || ${itemName.Equal[NULL]}) /return
/if (${buyListItems.Find[|${itemName}|]}) /return
/varset buyListItems ${buyListItems}|${itemName}|
/return

Sub AcceptQuantityPickup(int wantQty)
/if (!${Window[QuantityWnd].Open}) /return
/if (${wantQty} <= 0) /varset wantQty 1
/call ConfirmMerchantBuyQuantity ${wantQty}
/call WaitForCursor 500
/return

Sub AddToBuyCount(string itemName, int qty)
/declare atcTemp string local
/if (${qty} <= 0) /return
| Parchment/vellum is crafted — not sold on Scholar Klaz
/call IsParchmentIngredient "${itemName}"
/if (${Macro.Return.Equal[TRUE]}) /return
/varset atcTemp ${Ini[MQ2MacroTemp.ini,BuyCount,${itemName}]}
/if (${atcTemp.Length}==0 || ${atcTemp.Equal[NULL]}) {
	/ini MQ2MacroTemp.ini BuyCount "${itemName}" ${qty}
} else {
	/varcalc atcTemp ${Int[${atcTemp}]}+${qty}
	/ini MQ2MacroTemp.ini BuyCount "${itemName}" ${atcTemp}
}
/call RegisterBuyListItem "${itemName}"
/return

Sub AddParchmentKlazToBuyList
/declare apkQty int local 0
/if (${parchVopwBatches}==0 && ${parchCleanserBatches}==0) /return
/varset apkQty 0
/varcalc apkQty (${parchVopwBatches}*5)+${parchCleanserBatches}
/varcalc apkQty ${apkQty}-${FindItemCount[=Empty Vial]}
/if (${apkQty} > 0) /call AddToBuyCount "Empty Vial" ${apkQty}
/varset apkQty ${parchVopwBatches}
/varcalc apkQty ${apkQty}-${FindItemCount[=Gnomish Heat Source]}
/if (${apkQty} > 0) /call AddToBuyCount "Gnomish Heat Source" ${apkQty}
/varset apkQty 0
/varcalc apkQty ${parchVopwBatches}*4
/varcalc apkQty ${apkQty}-${FindItemCount[=Water Flask]}
/if (${apkQty} > 0) /call AddToBuyCount "Water Flask" ${apkQty}
/return

Sub MerchantSelectItem(string itemName)
/declare msiID int local ${Window[MW_PurchasePage].Child[MW_ItemList].List[=${itemName},2]}
/if (${msiID}==0 || ${msiID} > ${Window[MW_PurchasePage].Child[MW_ItemList].Items}) /return FALSE
/if (!${Window[MerchantWnd].Child[MW_Buy_Button].Enabled}) {
	/call WaitForMerchantList
	/delay 10
}
/nomodkey /notify MerchantWnd MW_ItemList listselect ${msiID} leftmouseup
/delay 15 ${Window[MerchantWnd].Child[MW_SelectedItemLabel].Text.Equal[${itemName}]}
/if (${Window[MerchantWnd].Child[MW_SelectedItemLabel].Text.Equal[${itemName}]}) /return TRUE
/nomodkey /notify MerchantWnd ItemList listselect ${msiID} leftmouseup
/delay 15 ${Window[MerchantWnd].Child[MW_SelectedItemLabel].Text.Equal[${itemName}]}
/if (${Window[MerchantWnd].Child[MW_SelectedItemLabel].Text.Equal[${itemName}]}) /return TRUE
/return FALSE

Sub BuyItemFromMerchant(string itemName, int qty)
/declare bimBefore int local
/declare bimTarget int local
/declare bimTry int local
/declare bimStillNeed int local
/declare bimWait int local
/declare bimHave int local
/declare bimUnit int local

/if (${qty} <= 0) /return TRUE
/call DismissQuantityWindow
/call ClearCursorFast
/varset bimBefore ${FindItemCount[=${itemName}]}
/varcalc bimTarget ${bimBefore}+${qty}
/if (${FindItemCount[=${itemName}]} >= ${bimTarget}) /return TRUE

/call MerchantSelectItem "${itemName}"
/if (!${Macro.Return.Equal[TRUE]}) {
	/echo WARNING: ${itemName} not found on this vendor!
	/return FALSE
}

/varcalc bimStillNeed ${bimTarget}-${FindItemCount[=${itemName}]}
/if (${bimStillNeed} > 0) /echo Buying ${bimStillNeed}x ${itemName}...

| Radix pattern: select item, MW_Buy_Button, confirm QuantityWnd, verify inventory
/for bimTry 1 to 3
	/call DismissQuantityWindow
	/call ClearCursorFast
	/if (!${Window[MerchantWnd].Open}) /return FALSE
	/varset bimHave ${FindItemCount[=${itemName}]}
	/if (${bimHave} >= ${bimTarget}) /return TRUE
	/varcalc bimStillNeed ${bimTarget}-${bimHave}
	/if (${bimStillNeed} <= 0) /return TRUE

	/call MerchantSelectItem "${itemName}"
	/if (!${Macro.Return.Equal[TRUE]}) /return FALSE

	/if (${bimStillNeed} > 1) {
		/nomodkey /notify MerchantWnd MW_Buy_Button leftmouseup
		/call ConfirmMerchantBuyQuantity ${bimStillNeed}
		/call ClearCursorFast
		/delay 15 ${FindItemCount[=${itemName}]} >= ${bimTarget}
	}

	/varset bimHave ${FindItemCount[=${itemName}]}
	/varcalc bimStillNeed ${bimTarget}-${bimHave}
	/for bimUnit 1 to ${bimStillNeed}
		/if (${FindItemCount[=${itemName}]} >= ${bimTarget}) /return TRUE
		/if (!${Window[MerchantWnd].Open}) /return FALSE
		/call DismissQuantityWindow
		/call MerchantSelectItem "${itemName}"
		/if (!${Macro.Return.Equal[TRUE]}) /return FALSE
		/nomodkey /ctrl /notify MerchantWnd MW_Buy_Button leftmouseup
		/delay 5
		/if (${Window[QuantityWnd].Open}) /call ConfirmMerchantBuyQuantity 1
		/call ClearCursorFast
	/next bimUnit

	/varset bimWait 0
	:BimCountWait
	/varset bimHave ${FindItemCount[=${itemName}]}
	/if (${bimHave} >= ${bimTarget}) /return TRUE
	/varcalc bimWait ${bimWait}+1
	/if (${bimWait} >= 40) /break
	/delay 5
	/doevents
	/goto :BimCountWait
/next bimTry

/call DismissQuantityWindow
/if (${FindItemCount[=${itemName}]} >= ${bimTarget}) /return TRUE
/echo ERROR: Failed to buy ${qty}x ${itemName} (have ${FindItemCount[=${itemName}]}, need ${bimTarget}).
/return FALSE

|-----------------------------------------------------------
| Sub CheckAllLevelsMissing: sets hasMissing if any
| ingredient across all levels is missing from inventory
|-----------------------------------------------------------
Sub CheckAllLevelsMissing
/declare calLevel int local
/declare calSection string local
/declare calCount int local
/declare calSpell int local
/declare calIng int local
/declare calIngName string local
/declare calHave int local
/declare calCopiesNeeded int local
/declare calNeedTotal int local

/varset hasMissing 0
/varset calLevel ${parchLevelStart}
:CalLoop
	/if (${calLevel} > ${parchLevelEnd}) /goto :CalDone
	/varset calSection ${ClassNameOuter}_${calLevel}
	/varset calCount ${Ini[${rlIniFile},${calSection},SpellCount]}
	/if (${calCount} > 0) {
		/for calSpell 1 to ${calCount}
			/varset calHave ${FindItemCount[=${Ini[${rlIniFile},${calSection},Spell${calSpell}]}]}
			/varcalc calCopiesNeeded ${TargetQty}-${calHave}
			/if (${calCopiesNeeded} <= 0) /continue
			/for calIng 1 to 20
				/varset calIngName ${Ini[${rlIniFile},${calSection},Spell${calSpell}_Ingredient${calIng}]}
				/if (${calIngName.Length}==0 || ${calIngName.Equal[NULL]}) /break
				/call IngredientNeedQty ${calSection} ${calSpell} "${calIngName}" ${calCopiesNeeded}
				/varset calNeedTotal ${Macro.Return}
				/if (${FindItemCount[=${calIngName}]} < ${calNeedTotal}) {
					/varset hasMissing 1
					/return
				}
			/next calIng
		/next calSpell
	}
	/varcalc calLevel ${calLevel}+1
	/goto :CalLoop
:CalDone
/return

|-----------------------------------------------------------
| Sub CheckAllLevelsVendors: scans all levels 66-70 and sets
| hasMissingKlaz / hasMissingVori based on what's still needed
|-----------------------------------------------------------
Sub CheckAllLevelsVendors
/declare cavLevel int local
/declare cavSection string local
/declare cavCount int local
/declare cavSpell int local
/declare cavIng int local
/declare cavIngName string local
/declare cavHave int local
/declare cavCopiesNeeded int local
/declare cavNeedTotal int local

/varset hasMissingKlaz 0
/varset hasMissingVori 0

/varset cavLevel ${parchLevelStart}
:CavLoop
	/if (${cavLevel} > ${parchLevelEnd}) /goto :CavDone
	/varset cavSection ${ClassNameOuter}_${cavLevel}
	/varset cavCount ${Ini[${rlIniFile},${cavSection},SpellCount]}
	/if (${cavCount} > 0) {
		/for cavSpell 1 to ${cavCount}
			/varset cavHave ${FindItemCount[=${Ini[${rlIniFile},${cavSection},Spell${cavSpell}]}]}
			/varcalc cavCopiesNeeded ${TargetQty}-${cavHave}
			/if (${cavCopiesNeeded} <= 0) /continue
			/for cavIng 1 to 20
				/varset cavIngName ${Ini[${rlIniFile},${cavSection},Spell${cavSpell}_Ingredient${cavIng}]}
				/if (${cavIngName.Length}==0 || ${cavIngName.Equal[NULL]}) /break
				/call IngredientNeedQty ${cavSection} ${cavSpell} "${cavIngName}" ${cavCopiesNeeded}
				/varset cavNeedTotal ${Macro.Return}
				/if (${FindItemCount[=${cavIngName}]} < ${cavNeedTotal}) {
					/if (${cavIngName.Equal[Tiny Dagger]} || ${cavIngName.Equal[Bone Chips]}) {
						/varset hasMissingVori 1
					} else {
						/varset hasMissingKlaz 1
					}
				}
			/next cavIng
		/next cavSpell
	}
	/varcalc cavLevel ${cavLevel}+1
	/goto :CavLoop
:CavDone
/return

|-----------------------------------------------------------
| Sub RunLevel: buys and combines all spells for one level
|-----------------------------------------------------------
Sub RunLevel(string LevelClass, string LevelNum)
/varset ClassNameOuter ${LevelClass}
/varset SpellLevelArgOuter ${LevelNum}
/varset SectionName ${LevelClass}_${LevelNum}
/varset SpellCount ${Ini[${rlIniFile},${SectionName},SpellCount]}
/if (${SpellCount}==0) {
	/echo ERROR: No config found for [${SectionName}] in ${rlIniFile}
	/return
}
/echo === Research Learn: ${LevelClass} Level ${LevelNum} (${SpellCount} spells) ===

/varset parchLevelStart ${LevelNum}
/varset parchLevelEnd ${LevelNum}
/echo === Checking parchment/vellum supply ===
/call TallyParchmentNeeds
/if (!${Macro.Return.Equal[TRUE]}) /return
/call BuyAllNeeded
/call ExecuteParchmentPrep
/if (!${Macro.Return.Equal[TRUE]}) /return
/call RequireResearchKit

/varset FailedSpells
/varset FailCount 0
/call CombineLevel

/if (${FailCount} > 0) {
	/echo === Retrying ${FailCount} failed spell(s) (max 3 passes) ===
	/call BuyForFailed
	/declare rlRetryPass int local 0
	/declare rlRetryMax int local 3
	/declare rlFailedList string local ${FailedSpells}
	/declare rlRetrySnapshot int local 0
	/for rlRetryPass 1 to ${rlRetryMax}
		/if (${rlFailedList.Length}==0) /break
		/varset rlRetrySnapshot ${FailCount}
		/varset RetryNum 1
		:RetryRunLoop
			/if (${RetryNum} > ${rlRetrySnapshot}) /goto :RetryRunDone
			/varset SpellName ${rlFailedList.Arg[${RetryNum},,]}
			/varset retrySpellNum 0
			/for SpellNum 1 to ${SpellCount}
				/if (${Ini[${rlIniFile},${SectionName},Spell${SpellNum}].Equal[${SpellName}]}) {
					/varset retrySpellNum ${SpellNum}
					/break
				}
			/next SpellNum
			/if (${retrySpellNum} > 0) {
				/call DoSpell ${retrySpellNum} ${SpellName}
			}
			/varcalc RetryNum ${RetryNum}+1
			/goto :RetryRunLoop
		:RetryRunDone
		/if (${FailCount}==0) /break
		/varset rlFailedList ${FailedSpells}
	/next rlRetryPass
}
/return

|-----------------------------------------------------------
| Sub CombineLevel: does combines for current SectionName
| Repeats each spell until TargetQty copies are in inventory
|-----------------------------------------------------------
Sub CombineLevel
/declare clHave int local
/declare clNeed int local
/declare clCopy int local
/call RequireResearchKit
/for SpellNum 1 to ${SpellCount}
	/varset SpellName ${Ini[${rlIniFile},${SectionName},Spell${SpellNum}]}
	/varset clHave ${FindItemCount[=${SpellName}]}
	/varcalc clNeed ${TargetQty}-${clHave}
	/if (${clNeed} <= 0) {
		/echo Already have ${clHave}/${TargetQty} ${SpellName}, skipping.
		/continue
	}
	/echo Need ${clNeed} more of ${SpellName} (have ${clHave}/${TargetQty})
	/for clCopy 1 to ${clNeed}
		/call DoSpell ${SpellNum} ${SpellName}
	/next clCopy
/next SpellNum
/return

|-----------------------------------------------------------
| Sub BuyAllNeeded: checks inventory, buys from Klaz,
| then Vori only if Tiny Dagger or Bone Chips needed
|-----------------------------------------------------------
Sub BuyAllNeeded
/declare banSpell int local
/declare banIng int local
/declare banIngName string local
/declare banHave int local
/declare banCopiesNeeded int local
/declare banNeedTotal int local

/echo Checking inventory...
/varset hasMissing 0
/varset hasMissingKlaz 0
/varset hasMissingVori 0

/declare banSpellStart int local 1
/declare banSpellEnd int local ${SpellCount}
/if (${importBatchMode}) {
	/declare banRIB int local
	/declare banRCount int local ${Ini[ResearchLearn_pass.ini,Pass,Count]}
	/declare banRItem string local
	/declare banRQty int local
	/declare banRHave int local
	/declare banRNeed int local
	/declare banRSection string local
	/declare banRSpellNum int local
	/for banRIB 1 to ${banRCount}
		/varset banRItem ${Ini[ResearchLearn_pass.ini,Pass,Item${banRIB}]}
		/varset banRQty ${Ini[ResearchLearn_pass.ini,Pass,Qty${banRIB}]}
		/if (${banRQty} <= 0) /varset banRQty 1
		/if (${banRItem.Length}==0 || ${banRItem.Equal[NULL]}) /continue
		/call FindSpellForImport ${banRIB} "${banRItem}"
		/if (!${Macro.Return.Equal[TRUE]}) /continue
		/varset banRSection ${SectionName}
		/varset banRSpellNum ${retrySpellNum}
		/varset banRHave ${FindItemCount[=${SpellName}]}
		/varcalc banRNeed ${banRQty}-${banRHave}
		/if (${banRNeed} <= 0) /continue
		/for banIng 1 to 20
			/varset banIngName ${Ini[${rlIniFile},${banRSection},Spell${banRSpellNum}_Ingredient${banIng}]}
			/if (${banIngName.Length}==0 || ${banIngName.Equal[NULL]}) /break
			/call IngredientNeedQty ${banRSection} ${banRSpellNum} "${banIngName}" ${banRNeed}
			/varset banNeedTotal ${Macro.Return}
			/if (${FindItemCount[=${banIngName}]} < ${banNeedTotal}) {
				/call IsParchmentIngredient "${banIngName}"
				/if (${Macro.Return.Equal[TRUE]}) /continue
				/varset hasMissing 1
				/if (${banIngName.Equal[Tiny Dagger]} || ${banIngName.Equal[Bone Chips]}) {
					/varset hasMissingVori 1
				} else {
					/varset hasMissingKlaz 1
				}
			}
		/next banIng
	/next banRIB
	/goto :BanCheckDone
}
/if (${singleSpellMode}) {
	/varset banSpellStart ${singleSpellNum}
	/varset banSpellEnd ${singleSpellNum}
}
/for banSpell ${banSpellStart} to ${banSpellEnd}
	/if (${singleSpellMode}) {
		/varset banCopiesNeeded ${singleSpellCopies}
	} else {
		/varset banHave ${FindItemCount[=${Ini[${rlIniFile},${SectionName},Spell${banSpell}]}]}
		/varcalc banCopiesNeeded ${TargetQty}-${banHave}
		/if (${banCopiesNeeded} <= 0) /continue
	}
	/for banIng 1 to 20
		/varset banIngName ${Ini[${rlIniFile},${SectionName},Spell${banSpell}_Ingredient${banIng}]}
		/if (${banIngName.Length}==0 || ${banIngName.Equal[NULL]}) /break
		/call IngredientNeedQty ${SectionName} ${banSpell} "${banIngName}" ${banCopiesNeeded}
		/varset banNeedTotal ${Macro.Return}
		/if (${FindItemCount[=${banIngName}]} < ${banNeedTotal}) {
			/call IsParchmentIngredient "${banIngName}"
			/if (${Macro.Return.Equal[TRUE]}) /continue
			/varset hasMissing 1
			/if (${banIngName.Equal[Tiny Dagger]} || ${banIngName.Equal[Bone Chips]}) {
				/varset hasMissingVori 1
			} else {
				/varset hasMissingKlaz 1
			}
		}
	/next banIng
/next banSpell
:BanCheckDone

/if (${hasMissing}==0 && ${needKlazAfterParch}==0) {
	/echo Vendor ingredients OK — continuing to craft.
	/return
}

/if (${hasMissingKlaz}==1 || ${needKlazAfterParch}==1) {
	/call NavAndBuy "Scholar Klaz"
} else {
	/echo Skipping Scholar Klaz - nothing needed from there.
}

/if (${hasMissingVori}==1) {
	/call NavAndBuy "Vori"
} else {
	/echo Skipping Vori - nothing needed from there.
}
/return

|-----------------------------------------------------------
| Sub CheckSpecialNeeded: checks if Tiny Dagger or Bone
| Chips are needed and missing across all levels
|-----------------------------------------------------------
Sub CheckSpecialNeeded
/declare csSpell int local
/declare csIng int local
/declare csIngName string local

/varset hasMissingSpecial 0

/for csSpell 1 to ${SpellCount}
	/for csIng 1 to 20
		/varset csIngName ${Ini[${rlIniFile},${SectionName},Spell${csSpell}_Ingredient${csIng}]}
		/if (${csIngName.Length}==0 || ${csIngName.Equal[NULL]}) /break
		/if (${csIngName.Equal[Tiny Dagger]} || ${csIngName.Equal[Bone Chips]}) {
			/if (!${FindItemCount[=${csIngName}]}) {
				/varset hasMissingSpecial 1
				/return
			}
		}
	/next csIng
/next csSpell
/return

|-----------------------------------------------------------
| Sub CheckSpecialNeededForFailed: checks if Tiny Dagger or
| Bone Chips are needed only for spells that actually failed
|-----------------------------------------------------------
Sub CheckSpecialNeededForFailed
/declare csnfNum int local
/declare csnfIng int local
/declare csnfIngName string local
/declare csnfSpellNum int local

/varset hasMissingSpecial 0

/for csnfNum 1 to ${FailCount}
	/varset SpellName ${FailedSpells.Arg[${csnfNum},,]}
	/call FindSpellSectionInClass ${ClassNameOuter} "${SpellName}"
	/if (!${Macro.Return.Equal[TRUE]}) /continue
	/varset csnfSpellNum ${retrySpellNum}
	/for csnfIng 1 to 20
		/varset csnfIngName ${Ini[${rlIniFile},${SectionName},Spell${csnfSpellNum}_Ingredient${csnfIng}]}
		/if (${csnfIngName.Length}==0 || ${csnfIngName.Equal[NULL]}) /break
		/if (${csnfIngName.Equal[Tiny Dagger]} || ${csnfIngName.Equal[Bone Chips]}) {
			/if (!${FindItemCount[=${csnfIngName}]}) {
				/varset hasMissingSpecial 1
				/return
			}
		}
	/next csnfIng
/next csnfNum
/return

|-----------------------------------------------------------
| Sub NavAndBuy: navs to NPC, opens vendor, buys all
| needed ingredients from current SectionName/SpellCount
| (for all levels if SpellLevelArg=all)
|-----------------------------------------------------------
Sub NavAndBuy(string NPCName)
/declare nabTry int local 0
/call NavToSpawn "${NPCName}"
/if (!${Macro.Return.Equal[TRUE]}) /return
/for nabTry 1 to 3
	/call OpenTargetMerchant
	/if (${Macro.Return.Equal[TRUE]}) /goto :NabOpenOk
	/face fast
	/keypress forward hold
	/delay 5
	/keypress forward
	/delay 2
/next nabTry
/echo ERROR: Could not open ${NPCName} after navigation.
/return
:NabOpenOk
/echo Buying from ${NPCName}...
/call DismissQuantityWindow
/call BuyFromVendorAllLevels
/call DismissQuantityWindow
/call ClearCursorFast
/notify MerchantWnd MW_Done_Button leftmouseup
/delay 10
/return

|-----------------------------------------------------------
| Sub NavAndBuyForSpell: navs to vendor and buys only
| what is needed for a single specific spell
|-----------------------------------------------------------
Sub NavAndBuyForSpell(string NPCName, int SpellNum)
/declare bfsIng int local
/declare bfsIngName string local
/declare bfsHaveQty int local
/declare bfsNeedQty int local
/declare bfsBuyQty int local
/declare bfsCountIng int local
/declare bfsCountName string local
/declare bfsTry int local 0

/echo Navigating to ${NPCName} for ${SpellName} ingredients...
/call NavToSpawn "${NPCName}"
/if (!${Macro.Return.Equal[TRUE]}) /return
/for bfsTry 1 to 3
	/call OpenTargetMerchant
	/if (${Macro.Return.Equal[TRUE]}) /goto :BfsOpenOk
	/delay 5
/next bfsTry
/return
:BfsOpenOk
/echo Buying from ${NPCName} for ${SpellName}...

/for bfsIng 1 to 20
	/varset bfsIngName ${Ini[${rlIniFile},${SectionName},Spell${SpellNum}_Ingredient${bfsIng}]}
	/if (${bfsIngName.Length}==0 || ${bfsIngName.Equal[NULL]}) /break
	/varset bfsNeedQty 0
	/for bfsCountIng 1 to 20
		/varset bfsCountName ${Ini[${rlIniFile},${SectionName},Spell${SpellNum}_Ingredient${bfsCountIng}]}
		/if (${bfsCountName.Length}==0 || ${bfsCountName.Equal[NULL]}) /break
		/if (${bfsCountName.Equal[${bfsIngName}]}) /varcalc bfsNeedQty ${bfsNeedQty}+1
	/next bfsCountIng
	/varset bfsHaveQty ${FindItemCount[=${bfsIngName}]}
	/varcalc bfsBuyQty ${bfsNeedQty}-${bfsHaveQty}
	/if (${bfsBuyQty} <= 0) /continue
	/call BuyItemFromMerchant "${bfsIngName}" ${bfsBuyQty}
/next bfsIng

/notify MerchantWnd MW_Done_Button leftmouseup
/delay 10
/return

|-----------------------------------------------------------
| Sub BuyFromVendorAllLevels: counts all ingredients needed
| across all levels 66-70 using temp INI, buys each once
|-----------------------------------------------------------
Sub BuyFromVendorAllLevels
/declare bfalLevel int local
/declare bfalSection string local
/declare bfalCount int local
/declare bfalSpell int local
/declare bfalIng int local
/declare bfalIngName string local
/declare bfalNeedQty string local
/declare bfalHaveQty int local
/declare bfalBuyQty int local
/declare bfalTempVal string local
/declare bfalHave int local
/declare bfalCopiesNeeded int local
/declare bfalIngNeed int local
/declare bfalIdx int local 0
/declare bfalItem string local

| Pass 1: Count all ingredients across all levels into temp INI
/echo Counting ingredients needed...
/varset buyListItems
/call AddParchmentKlazToBuyList
/if (${importBatchMode}) {
	/declare bfalRIB int local
	/declare bfalRCount int local ${Ini[ResearchLearn_pass.ini,Pass,Count]}
	/declare bfalRItem string local
	/declare bfalRQty int local
	/declare bfalRHave int local
	/declare bfalRNeed int local
	/declare bfalRSection string local
	/declare bfalRSpellNum int local
	/for bfalRIB 1 to ${bfalRCount}
		/varset bfalRItem ${Ini[ResearchLearn_pass.ini,Pass,Item${bfalRIB}]}
		/varset bfalRQty ${Ini[ResearchLearn_pass.ini,Pass,Qty${bfalRIB}]}
		/if (${bfalRQty} <= 0) /varset bfalRQty 1
		/if (${bfalRItem.Length}==0 || ${bfalRItem.Equal[NULL]}) /continue
		/call FindSpellForImport ${bfalRIB} "${bfalRItem}"
		/if (!${Macro.Return.Equal[TRUE]}) /continue
		/varset bfalRSection ${SectionName}
		/varset bfalRSpellNum ${retrySpellNum}
		/varset bfalRHave ${FindItemCount[=${SpellName}]}
		/varcalc bfalRNeed ${bfalRQty}-${bfalRHave}
		/if (${bfalRNeed} <= 0) /continue
		/for bfalIng 1 to 20
			/varset bfalIngName ${Ini[${rlIniFile},${bfalRSection},Spell${bfalRSpellNum}_Ingredient${bfalIng}]}
			/if (${bfalIngName.Length}==0 || ${bfalIngName.Equal[NULL]}) /break
			/call IngredientNeedQty ${bfalRSection} ${bfalRSpellNum} "${bfalIngName}" ${bfalRNeed}
			/varset bfalIngNeed ${Macro.Return}
			/call AddToBuyCount "${bfalIngName}" ${bfalIngNeed}
		/next bfalIng
	/next bfalRIB
	/goto :BfalCountDone
}
/if (${singleSpellMode}) {
	/for bfalIng 1 to 20
		/varset bfalIngName ${Ini[${rlIniFile},${SectionName},Spell${singleSpellNum}_Ingredient${bfalIng}]}
		/if (${bfalIngName.Length}==0 || ${bfalIngName.Equal[NULL]}) /break
		/call IngredientNeedQty ${SectionName} ${singleSpellNum} "${bfalIngName}" ${singleSpellCopies}
		/varset bfalIngNeed ${Macro.Return}
		/call AddToBuyCount "${bfalIngName}" ${bfalIngNeed}
	/next bfalIng
	/goto :BfalCountDone
}
/varset bfalLevel ${parchLevelStart}
:BfalCountLevel
	/if (${bfalLevel} > ${parchLevelEnd}) /goto :BfalCountDone
	/varset bfalSection ${ClassNameOuter}_${bfalLevel}
	/varset bfalCount ${Ini[${rlIniFile},${bfalSection},SpellCount]}
	/if (${bfalCount} > 0) {
		/for bfalSpell 1 to ${bfalCount}
			/varset bfalHave ${FindItemCount[=${Ini[${rlIniFile},${bfalSection},Spell${bfalSpell}]}]}
			/varset bfalCopiesNeeded 0
			/varcalc bfalCopiesNeeded ${TargetQty}-${bfalHave}
			/if (${bfalCopiesNeeded} <= 0) /continue
			/for bfalIng 1 to 20
				/varset bfalIngName ${Ini[${rlIniFile},${bfalSection},Spell${bfalSpell}_Ingredient${bfalIng}]}
				/if (${bfalIngName.Length}==0 || ${bfalIngName.Equal[NULL]}) /break
				/call IngredientNeedQty ${bfalSection} ${bfalSpell} "${bfalIngName}" ${bfalCopiesNeeded}
				/varset bfalIngNeed ${Macro.Return}
				/call AddToBuyCount "${bfalIngName}" ${bfalIngNeed}
			/next bfalIng
		/next bfalSpell
	}
	/varcalc bfalLevel ${bfalLevel}+1
	/goto :BfalCountLevel
:BfalCountDone

| Pass 2: Buy each unique ingredient once
/echo Buying ingredients...
:BfalBuyItemLoop
/varcalc bfalIdx ${bfalIdx}+1
/varset bfalItem ${buyListItems.Arg[${bfalIdx},|]}
/if (${bfalItem.Length}==0) /goto :BfalBuyDone
/call DismissQuantityWindow
/call ClearCursorFast
/if (!${Window[MerchantWnd].Open}) {
	/echo ERROR: Merchant window closed during buy pass!
	/return
}
/varset bfalNeedQty ${Ini[MQ2MacroTemp.ini,BuyCount,${bfalItem}]}
/if (${bfalNeedQty.Length}==0 || ${bfalNeedQty.Equal[NULL]}) /goto :BfalBuyItemLoop
/varset bfalHaveQty ${FindItemCount[=${bfalItem}]}
/varcalc bfalBuyQty ${Int[${bfalNeedQty}]}-${bfalHaveQty}
/if (${bfalBuyQty} <= 0) {
	/echo Have enough ${bfalItem} (${bfalHaveQty}/${bfalNeedQty})
	/ini MQ2MacroTemp.ini BuyCount "${bfalItem}" NULL
	/goto :BfalBuyItemLoop
}
/call BuyItemFromMerchant "${bfalItem}" ${bfalBuyQty}
/call DismissQuantityWindow
/call ClearCursorFast
/varset bfalHaveQty ${FindItemCount[=${bfalItem}]}
/if (${Macro.Return.Equal[TRUE]} || ${bfalHaveQty} >= ${Int[${bfalNeedQty}]}) {
	/ini MQ2MacroTemp.ini BuyCount "${bfalItem}" NULL
} else {
	/echo WARNING: Still short ${bfalItem} after buy (${bfalHaveQty}/${bfalNeedQty}) - continuing.
	/ini MQ2MacroTemp.ini BuyCount "${bfalItem}" NULL
}
/goto :BfalBuyItemLoop
:BfalBuyDone
/return

|-----------------------------------------------------------
| Sub BuyForFailed: buys ingredients for failed spells
|-----------------------------------------------------------
Sub BuyForFailed
/declare bffNum int local
/declare bffIng int local
/declare bffIngName string local
/declare bffSpellNum int local

/varset hasMissingKlaz 0
/varset hasMissingVori 0

| Walk all failed spells and categorize what's missing by vendor
/for bffNum 1 to ${FailCount}
	/varset SpellName ${FailedSpells.Arg[${bffNum},,]}
	/call FindSpellSectionInClass ${ClassNameOuter} "${SpellName}"
	/if (!${Macro.Return.Equal[TRUE]}) /continue
	/varset bffSpellNum ${retrySpellNum}
	/for bffIng 1 to 20
		/varset bffIngName ${Ini[${rlIniFile},${SectionName},Spell${bffSpellNum}_Ingredient${bffIng}]}
		/if (${bffIngName.Length}==0 || ${bffIngName.Equal[NULL]}) /break
		/if (!${FindItemCount[=${bffIngName}]}) {
			/if (${bffIngName.Equal[Tiny Dagger]} || ${bffIngName.Equal[Bone Chips]}) {
				/varset hasMissingVori 1
			} else {
				/varset hasMissingKlaz 1
			}
		}
	/next bffIng
/next bffNum

/if (${hasMissingKlaz}==1) {
	/call NavAndBuyFailed "Scholar Klaz"
} else {
	/echo Skipping Scholar Klaz for retry - nothing needed from there.
}
/if (${hasMissingVori}==1) {
	/call NavAndBuyFailed "Vori"
} else {
	/echo Skipping Vori for retry - nothing needed from there.
}
/return

|-----------------------------------------------------------
| Sub NavAndBuyFailed
|-----------------------------------------------------------
Sub NavAndBuyFailed(string NPCName)
/declare nabfTry int local 0
/call NavToSpawn "${NPCName}"
/if (!${Macro.Return.Equal[TRUE]}) /return
/for nabfTry 1 to 3
	/call OpenTargetMerchant
	/if (${Macro.Return.Equal[TRUE]}) /goto :NabfOpenOk
	/delay 5
/next nabfTry
/return
:NabfOpenOk
/call BuyForFailedFromVendor
/notify MerchantWnd MW_Done_Button leftmouseup
/delay 10
/return

|-----------------------------------------------------------
| Sub BuyForFailedFromVendor
| Tallies total ingredients needed across ALL failed spells
| then buys (needed - have) for each, so shared ingredients
| between multiple failed spells are bought correctly.
|-----------------------------------------------------------
Sub BuyForFailedFromVendor
/declare bffvNum int local
/declare bffvIng int local
/declare bffvIngName string local
/declare bffvHaveQty int local
/declare bffvBuyQty int local
/declare bffvTempVal string local
/declare bffvIngNeed int local

| Pass 1: Count total ingredients needed across all failed spells
/for bffvNum 1 to ${FailCount}
	/varset SpellName ${FailedSpells.Arg[${bffvNum},,]}
	/call FindSpellSectionInClass ${ClassNameOuter} "${SpellName}"
	/if (!${Macro.Return.Equal[TRUE]}) /continue
	/for bffvIng 1 to 20
		/varset bffvIngName ${Ini[${rlIniFile},${SectionName},Spell${retrySpellNum}_Ingredient${bffvIng}]}
		/if (${bffvIngName.Length}==0 || ${bffvIngName.Equal[NULL]}) /break
		/call IngredientNeedQty ${SectionName} ${retrySpellNum} "${bffvIngName}" 1
		/varset bffvIngNeed ${Macro.Return}
		/varset bffvTempVal ${Ini[MQ2MacroTemp.ini,FailBuyCount,${bffvIngName}]}
		/if (${bffvTempVal.Length}==0 || ${bffvTempVal.Equal[NULL]}) {
			/ini MQ2MacroTemp.ini FailBuyCount "${bffvIngName}" ${bffvIngNeed}
		} else {
			/varcalc bffvTempVal ${Int[${bffvTempVal}]}+${bffvIngNeed}
			/ini MQ2MacroTemp.ini FailBuyCount "${bffvIngName}" ${bffvTempVal}
		}
	/next bffvIng
/next bffvNum

| Pass 2: Buy each ingredient in correct quantity (needed - have)
/for bffvNum 1 to ${FailCount}
	/varset SpellName ${FailedSpells.Arg[${bffvNum},,]}
	/call FindSpellSectionInClass ${ClassNameOuter} "${SpellName}"
	/if (!${Macro.Return.Equal[TRUE]}) /continue
	/for bffvIng 1 to 20
		/varset bffvIngName ${Ini[${rlIniFile},${SectionName},Spell${retrySpellNum}_Ingredient${bffvIng}]}
		/if (${bffvIngName.Length}==0 || ${bffvIngName.Equal[NULL]}) /break
		/varset bffvTempVal ${Ini[MQ2MacroTemp.ini,FailBuyCount,${bffvIngName}]}
		/if (${bffvTempVal.Length}==0 || ${bffvTempVal.Equal[NULL]}) /continue
		/ini MQ2MacroTemp.ini FailBuyCount "${bffvIngName}" NULL
		/varset bffvHaveQty ${FindItemCount[=${bffvIngName}]}
		/varcalc bffvBuyQty ${Int[${bffvTempVal}]}-${bffvHaveQty}
		/if (${bffvBuyQty} <= 0) {
			/echo Have enough ${bffvIngName} (${bffvHaveQty}/${bffvTempVal})
			/continue
		}
		/call BuyItemFromMerchant "${bffvIngName}" ${bffvBuyQty}
	/next bffvIng
/next bffvNum
/return

|-----------------------------------------------------------
| Sub CheckMissingFailed
|-----------------------------------------------------------
Sub CheckMissingFailed
/declare cmfNum int local
/declare cmfIng int local
/declare cmfIngName string local

/varset hasMissingFailed 0

/for cmfNum 1 to ${FailCount}
	/varset SpellName ${FailedSpells.Arg[${cmfNum},,]}
	/call FindSpellSectionInClass ${ClassNameOuter} "${SpellName}"
	/if (!${Macro.Return.Equal[TRUE]}) /continue
	/for cmfIng 1 to 20
		/varset cmfIngName ${Ini[${rlIniFile},${SectionName},Spell${retrySpellNum}_Ingredient${cmfIng}]}
		/if (${cmfIngName.Length}==0 || ${cmfIngName.Equal[NULL]}) /break
		/if (!${FindItemCount[=${cmfIngName}]}) {
			/varset hasMissingFailed 1
			/return
		}
	/next cmfIng
/next cmfNum
/return

Sub TryInlineVendorBuy(int SpellNum)
/declare tivIng int local
/declare tivIngName string local
/declare tivNeedKlaz int local 0
/declare tivNeedVori int local 0

/for tivIng 1 to 20
	/varset tivIngName ${Ini[${rlIniFile},${SectionName},Spell${SpellNum}_Ingredient${tivIng}]}
	/if (${tivIngName.Length}==0 || ${tivIngName.Equal[NULL]}) /break
	/call IngredientNeedQty ${SectionName} ${SpellNum} "${tivIngName}" 1
	/if (${FindItemCount[=${tivIngName}]} >= ${Macro.Return}) /continue
	/call IsParchmentIngredient "${tivIngName}"
	/if (${Macro.Return.Equal[TRUE]}) /continue
	/if (${tivIngName.Equal[Tiny Dagger]} || ${tivIngName.Equal[Bone Chips]}) {
		/varset tivNeedVori 1
	} else {
		/varset tivNeedKlaz 1
	}
/next tivIng

/if (${tivNeedKlaz}) /call NavAndBuyForSpell "Scholar Klaz" ${SpellNum}
/if (${tivNeedVori}) /call NavAndBuyForSpell "Vori" ${SpellNum}
/return

|-----------------------------------------------------------
| Sub DoSpell
|-----------------------------------------------------------
Sub DoSpell(int SpellNum, string SpellName)
/declare ing int local
/declare ingName string local
/declare packSlot int local
/declare dsIng int local
/declare dsIngName string local
/declare dsNeedQty int local
/declare dsMissing int local 0
/declare dsVendorMissing int local 0
/declare dsHaveBefore int local 0

/call ScrollHaveCount "${SpellName}"
/varset dsHaveBefore ${Macro.Return}

/echo --- Combining: ${SpellName} ---

/for dsIng 1 to 20
	/varset dsIngName ${Ini[${rlIniFile},${SectionName},Spell${SpellNum}_Ingredient${dsIng}]}
	/if (${dsIngName.Length}==0 || ${dsIngName.Equal[NULL]}) /break
	/call IngredientNeedQty ${SectionName} ${SpellNum} "${dsIngName}" 1
	/varset dsNeedQty ${Macro.Return}
	/if (${FindItemCount[=${dsIngName}]} < ${dsNeedQty}) {
		/varset dsMissing 1
		/call IsParchmentIngredient "${dsIngName}"
		/if (${Macro.Return.Equal[TRUE]}) {
			/echo Missing parchment ${dsIngName} for ${SpellName} - attempting replenish...
			/if (${dsIngName.Equal[Fine Runic Vellum]}) {
				/call ReplenishParchmentIngredients "Fine Runic Vellum Solution" "Sooty Fine Runic Vellum" "Celestial Cleanser" 1
				/call MakeOneParchment "Fine Runic Vellum Solution" "Sooty Fine Runic Vellum" "Fine Runic Vellum"
			}
			/if (${dsIngName.Equal[Fine Vellum]}) {
				/call ReplenishParchmentIngredients "Fine Vellum Solution" "Grubby Fine Vellum" "Celestial Cleanser" 1
				/call MakeOneParchment "Fine Vellum Solution" "Grubby Fine Vellum" "Fine Vellum"
			}
			/if (${dsIngName.Equal[Vellum]}) {
				/call ReplenishParchmentIngredients "Vellum Solution" "Dirty Vellum" "Celestial Cleanser" 1
				/call MakeOneParchment "Vellum Solution" "Dirty Vellum" "Vellum"
			}
			/if (${dsIngName.Equal[Runic Vellum]}) {
				/call ReplenishParchmentIngredients "Runic Vellum Solution" "Shabby Runic Vellum" "Celestial Cleanser" 1
				/call MakeOneParchment "Runic Vellum Solution" "Shabby Runic Vellum" "Runic Vellum"
			}
			/if (${dsIngName.Equal[Fine Runic Parchment]}) {
				/call ReplenishParchmentIngredients "Fine Runic Parchment Solution" "Grimy Fine Runic Parchment" "Celestial Cleanser" 1
				/call MakeOneParchment "Fine Runic Parchment Solution" "Grimy Fine Runic Parchment" "Fine Runic Parchment"
			}
		} else {
			/varset dsVendorMissing 1
			/echo Missing vendor ingredient ${dsIngName} x${dsNeedQty} for ${SpellName} (have ${FindItemCount[=${dsIngName}]})
		}
	}
/next dsIng

/if (${dsVendorMissing}) {
	/echo Missing vendor mats for ${SpellName} - attempting inline buy...
	/call TryInlineVendorBuy ${SpellNum}
	/varset dsVendorMissing 0
	/varset dsMissing 0
	/for dsIng 1 to 20
		/varset dsIngName ${Ini[${rlIniFile},${SectionName},Spell${SpellNum}_Ingredient${dsIng}]}
		/if (${dsIngName.Length}==0 || ${dsIngName.Equal[NULL]}) /break
		/call IngredientNeedQty ${SectionName} ${SpellNum} "${dsIngName}" 1
		/varset dsNeedQty ${Macro.Return}
		/if (${FindItemCount[=${dsIngName}]} < ${dsNeedQty}) {
			/call IsParchmentIngredient "${dsIngName}"
			/if (${Macro.Return.Equal[TRUE]}) /varset dsMissing 1
			/if (!${Macro.Return.Equal[TRUE]}) /varset dsVendorMissing 1
		}
	/next dsIng
	/if (${dsVendorMissing} || ${dsMissing}) {
		/call LogFail "${SpellName}" "missing_vendor_ingredient"
		/call MarkFailed "${SpellName}"
		/return
	}
}

/if (${dsMissing}) {
	| Re-check after parchment replenish
	/varset dsMissing 0
	/for dsIng 1 to 20
		/varset dsIngName ${Ini[${rlIniFile},${SectionName},Spell${SpellNum}_Ingredient${dsIng}]}
		/if (${dsIngName.Length}==0 || ${dsIngName.Equal[NULL]}) /break
		/call IngredientNeedQty ${SectionName} ${SpellNum} "${dsIngName}" 1
		/varset dsNeedQty ${Macro.Return}
		/if (${FindItemCount[=${dsIngName}]} < ${dsNeedQty}) /varset dsMissing 1
	/next dsIng
	/if (${dsMissing}) {
		/call LogFail "${SpellName}" "missing_after_replenish"
		/call MarkFailed "${SpellName}"
		/return
	}
}

/call EnsureResearchKitOpen
/if (!${Macro.Return.Equal[TRUE]}) {
	/call LogFail "${SpellName}" "kit_open_failed"
	/call MarkFailed "${SpellName}"
	/return
}
/call CloseBlockingWindows
/if (${Window[MerchantWnd].Open}) {
	/echo ERROR: Merchant still open — cannot pick items into research kit.
	/call LogFail "${SpellName}" "merchant_open"
	/call MarkFailed "${SpellName}"
	/return
}
/call ClearResearchKit

/declare dsIngCount int local 0
/declare dsPlaced int local 0
/for ing 1 to 20
	/varset ingName ${Ini[${rlIniFile},${SectionName},Spell${SpellNum}_Ingredient${ing}]}
	/if (${ingName.Length}==0 || ${ingName.Equal[NULL]}) /break
	/varcalc dsIngCount ${dsIngCount}+1
/next ing
/if (${dsIngCount}==0) {
	/echo ERROR: No ingredients in [${SectionName}] Spell${SpellNum} for ${SpellName} — check researchlearn.ini
	/call LogFail "${SpellName}" "no_ingredients"
	/call MarkFailed "${SpellName}"
	/return
}

/varset packSlot 1
/for ing 1 to 20
	/varset ingName ${Ini[${rlIniFile},${SectionName},Spell${SpellNum}_Ingredient${ing}]}
	/if (${ingName.Length}==0 || ${ingName.Equal[NULL]}) /break
	/echo Placing ${ingName} -> kit slot ${packSlot}...
	/if (!${FindItemCount[=${ingName}]}) {
		/echo WARNING: ${ingName} not found, skipping...
		/call LogFail "${SpellName}" "missing_${ingName}"
		/call MarkFailed "${SpellName}"
		/return
	}
	/call PlaceItemInKit "${ingName}" ${packSlot}
	/if (!${Macro.Return.Equal[TRUE]}) {
		/echo WARNING: Failed to place ${ingName} in research kit slot ${packSlot}
		/echo \ayTip:\ax Open bags (i), close merchant/bank; kit in top-level pack${kitPack}.
		/call DumpKitSlots
		/call LogFail "${SpellName}" "place_failed_${ingName}"
		/call MarkFailed "${SpellName}"
		/return
	}
	/varcalc dsPlaced ${dsPlaced}+1
	/varcalc packSlot ${packSlot}+1
/next ing

/echo \agKit ready:\ax ${dsPlaced}/${dsIngCount} ingredients placed
/if (${showDebug}) /call DumpKitSlots
/if (${dsPlaced} < ${dsIngCount}) {
	/echo ERROR: Only placed ${dsPlaced}/${dsIngCount} ingredients - will not combine.
	/call LogFail "${SpellName}" "kit_incomplete"
	/call MarkFailed "${SpellName}"
	/return
}

/echo Combining ${SpellName}...
/varset CurrentSpell ${SpellName}
/if (!${Window[ContainerCombine_Items].Open}) {
	/echo ERROR: Research kit window closed before combine.
	/call LogFail "${SpellName}" "kit_closed"
	/call MarkFailed "${SpellName}"
	/return
}
/call DoKitCombine
/call WaitForSpellCombine "${SpellName}" ${dsHaveBefore}
/if (${Macro.Return.Equal[TRUE]}) {
	/if (${Cursor.ID}) {
		/call CursorMatchesScroll "${SpellName}"
		/if (${Macro.Return.Equal[TRUE]}) {
			/echo \agSuccess! ${Cursor.Name} on cursor.
			/autoinv
			/delay 20 !${Cursor.ID}
			/if (${Cursor.ID}) {
				/echo \arERROR: Inventory full - could not store ${SpellName}.
				/call LogFail "${SpellName}" "inventory_full"
				/call ForceClearCursor
				/call MarkFailed "${SpellName}"
				/return
			}
		} else {
			/call ForceClearCursor
		}
	}
	/call ScrollHaveCount "${SpellName}"
	/echo \agSuccess! ${SpellName} crafted (now have ${Macro.Return}).
	/call ClearResearchKit
	/return
}
:CombineFailed
/echo \arFailed: ${SpellName} combine failed, marking for retry.
/if (${combineFailed}) /echo \ayHint:\ax EQ rejected the combine (skill/components). Check kit slots below.
/echo \ayKit contents:\ax
/call DumpKitSlots
/call LogFail "${SpellName}" "combine_failed"
/call MarkFailed "${SpellName}"
/if (${Cursor.ID}) /call ForceClearCursor
/call ClearResearchKit
/return

Sub MarkFailed(string SpellName)
/if (${FailedSpells.Find[${SpellName}]}) /return
/varcalc FailCount ${FailCount}+1
/if (${FailedSpells.Length}==0) {
	/varset FailedSpells ${SpellName}
} else {
	/varset FailedSpells ${FailedSpells},${SpellName}
}
/return

Sub Event_Success
/varset combineSucceeded TRUE
/return

Sub Event_FailedIt
/varset combineFailed TRUE
/return

Sub Event_CombineCant
/varset combineFailed TRUE
/return

Sub Event_CombineMissing
/varset combineFailed TRUE
/return

Sub Event_CombineEmpty
/varset combineFailed TRUE
/return

|-----------------------------------------------------------
| Sub VerifySpells: checks all spells for the run were made,
| attempts any missing ones one final time
|-----------------------------------------------------------
Sub VerifySpells
/declare vsLevel int local
/declare vsSection string local
/declare vsCount int local
/declare vsNum int local
/declare vsSpellName string local
/declare vsHave int local
/declare vsNeed int local
/declare vsCopy int local
/declare vsMissing int local 0
/declare vsAnyMissing int local 0

/varset vsLevel ${parchLevelStart}
/if (!${SpellLevelArgOuter.Equal[all]}) {
	/varset vsLevel ${SpellLevelArgOuter}
}

| Pass 1: detect any missing spells
:VsScanLoop
	/varset vsSection ${ClassNameOuter}_${vsLevel}
	/varset vsCount ${Ini[${rlIniFile},${vsSection},SpellCount]}
	/if (${vsCount} > 0) {
		/for vsNum 1 to ${vsCount}
			/varset vsSpellName ${Ini[${rlIniFile},${vsSection},Spell${vsNum}]}
			/varset vsHave ${FindItemCount[=${vsSpellName}]}
			/varcalc vsNeed ${TargetQty}-${vsHave}
			/if (${vsNeed} > 0) /varset vsAnyMissing 1
		/next vsNum
	}
	/if (${SpellLevelArgOuter.Equal[all]}) {
		/varcalc vsLevel ${vsLevel}+1
		/if (${vsLevel} <= ${parchLevelEnd}) /goto :VsScanLoop
	}

| Pass 2: one buy pass for all missing, then combine
/if (${vsAnyMissing}) {
	/echo Verification found missing spells - buying ingredients once...
	/if (${SpellLevelArgOuter.Equal[all]}) {
		/call CheckAllLevelsMissing
		/if (${hasMissing}) {
			/call CheckAllLevelsVendors
			/if (${hasMissingKlaz}==1 || ${needKlazAfterParch}==1) /call NavAndBuy "Scholar Klaz"
			/if (${hasMissingVori}==1) /call NavAndBuy "Vori"
		}
	} else {
		/call BuyAllNeeded
	}
	/call RequireResearchKit
}

/varset vsLevel ${parchLevelStart}
/if (!${SpellLevelArgOuter.Equal[all]}) {
	/varset vsLevel ${SpellLevelArgOuter}
}

:VsLevelLoop
	/varset vsSection ${ClassNameOuter}_${vsLevel}
	/varset vsCount ${Ini[${rlIniFile},${vsSection},SpellCount]}
	/if (${vsCount} > 0) {
		/varset SectionName ${vsSection}
		/varset SpellCount ${vsCount}
		/for vsNum 1 to ${vsCount}
			/varset vsSpellName ${Ini[${rlIniFile},${vsSection},Spell${vsNum}]}
			/varset vsHave ${FindItemCount[=${vsSpellName}]}
			/varcalc vsNeed ${TargetQty}-${vsHave}
			/if (${vsNeed} > 0) {
				/echo MISSING ${vsNeed}x ${vsSpellName} (have ${vsHave}/${TargetQty}) - attempting...
				/for vsCopy 1 to ${vsNeed}
					/call DoSpell ${vsNum} ${vsSpellName}
				/next vsCopy
				/varcalc vsMissing ${vsMissing}+1
			}
		/next vsNum
	}
	/if (${SpellLevelArgOuter.Equal[all]}) {
		/varcalc vsLevel ${vsLevel}+1
		/if (${vsLevel} <= ${parchLevelEnd}) /goto :VsLevelLoop
	}

/if (${vsMissing}==0) {
	/echo All spells verified - ${TargetQty}x of each confirmed!
} else {
	/echo Verification complete - attempted ${vsMissing} missing spell(s).
}
/return

|-----------------------------------------------------------
| Sub RunSingleSpell: searches all sections for a spell by
| name and runs it N times (TargetQty - have)
|-----------------------------------------------------------
Sub RunSingleSpell(string RequestedSpell)
/declare rssNum int local
/declare rssHave int local
/declare rssNeed int local
/declare rssCopy int local

/echo === Searching for Spell: ${RequestedSpell} ===
/declare rssFound string local FALSE
/if (${singleSpellClassHint.Length} && !${singleSpellClassHint.Equal[NULL]}) {
	/call FindSpellSectionInClass ${singleSpellClassHint} "${RequestedSpell}"
	/varset rssFound ${Macro.Return}
}
/if (!${rssFound.Equal[TRUE]}) {
	/call FindSpellSectionAny "${RequestedSpell}"
	/varset rssFound ${Macro.Return}
}
/if (!${rssFound.Equal[TRUE]}) {
	/echo ERROR: Could not find "${RequestedSpell}" in any section of ${rlIniFile}.
	/return
}

/varset rssNum ${retrySpellNum}
/varset ClassNameOuter ${SectionName.Arg[1,_]}
/varset SpellLevelArgOuter ${SectionName.Arg[2,_]}
/varset parchLevelStart ${SectionName.Arg[2,_]}
/varset parchLevelEnd ${SectionName.Arg[2,_]}

/echo Found ${SpellName} in [${SectionName}]

/varset rssHave ${FindItemCount[=${SpellName}]}
/varcalc rssNeed ${TargetQty}-${rssHave}
/if (${rssNeed} <= 0) {
	/echo Already have ${rssHave}/${TargetQty} ${SpellName}, nothing to do.
	/return
}

/echo Need ${rssNeed} more of ${SpellName} (have ${rssHave}/${TargetQty})
/varset singleSpellMode 1
/varset singleSpellNum ${rssNum}
/varset singleSpellCopies ${rssNeed}
/echo === Single-spell mode: ${SpellName} x${rssNeed} only (not full class batch) ===
/if (${clearTempOnStart}) /call ClearBuyTempIni
/echo === Checking parchment/vellum supply ===
/call TallyParchmentNeeds
/if (!${Macro.Return.Equal[TRUE]}) /goto :RssAbort
/call BuyAllNeeded
/call ExecuteParchmentPrep
/if (!${Macro.Return.Equal[TRUE]}) /goto :RssAbort
/call RequireResearchKit
/echo === Craft phase: ${SpellName} x${rssNeed} ===

/varset FailedSpells
/varset FailCount 0
/for rssCopy 1 to ${rssNeed}
	/call DoSpell ${rssNum} ${SpellName}
/next rssCopy

/if (${FailCount} > 0) {
	/echo === Retrying ${FailCount} failed attempt(s) (max 3 passes) ===
	/call BuyForFailed
	/declare rssRetryPass int local 0
	/for rssRetryPass 1 to 3
		/if (${FailCount}==0) /break
		/varset FailCount 0
		/varset FailedSpells
		/call DoSpell ${rssNum} ${SpellName}
	/next rssRetryPass
}

/varset rssHave ${FindItemCount[=${SpellName}]}
/if (${rssHave} >= ${TargetQty}) {
	/echo All verified - have ${rssHave}/${TargetQty} ${SpellName}!
} else {
	/echo WARNING: Only have ${rssHave}/${TargetQty} ${SpellName} after all attempts.
}
/call BankLeftoverDroppedParchments
/if (${clearTempOnEnd}) /call ClearBuyTempIni
:RssAbort
/varset singleSpellMode 0
/return

|-----------------------------------------------------------
| Sub RunImportBatch: one Klaz trip + one parchment prep,
| then craft each spell from ResearchLearn_pass.ini queue
|-----------------------------------------------------------
Sub RunImportBatch
/declare ribI int local
/declare ribCount int local ${Ini[ResearchLearn_pass.ini,Pass,Count]}
/declare ribItem string local
/declare ribQty int local
/declare ribHave int local
/declare ribNeed int local
/declare ribCopy int local
/declare ribRetryPass int local

/if (${ribCount} <= 0) {
	/echo ERROR: _import mode but Config\ResearchLearn_pass.ini is missing [Pass] Count=
	/return
}

/echo === Import batch: ${ribCount} spell(s) — merged buy + parchment prep ===
/varset parchLevelStart 66
/varset parchLevelEnd 70
/if (${clearTempOnStart}) /call ClearBuyTempIni

/varset importBatchMode 1
/echo === Checking parchment/vellum supply (import batch) ===
/call TallyParchmentNeeds
/if (!${Macro.Return.Equal[TRUE]}) /goto :RibAbort
/call BuyAllNeeded
/call ExecuteParchmentPrep
/if (!${Macro.Return.Equal[TRUE]}) /goto :RibAbort
/call RequireResearchKit

/echo === Craft phase: import batch ===
/for ribI 1 to ${ribCount}
	/varset ribItem ${Ini[ResearchLearn_pass.ini,Pass,Item${ribI}]}
	/varset ribQty ${Ini[ResearchLearn_pass.ini,Pass,Qty${ribI}]}
	/if (${ribQty} <= 0) /varset ribQty 1
	/if (${ribItem.Length}==0 || ${ribItem.Equal[NULL]}) /continue
	/call FindSpellForImport ${ribI} "${ribItem}"
	/if (!${Macro.Return.Equal[TRUE]}) {
		/echo ERROR: Import batch — could not find "${ribItem}" in ${rlIniFile}, skipping.
		/continue
	}
	/varset ClassNameOuter ${SectionName.Arg[1,_]}
	/varset parchLevelStart ${SectionName.Arg[2,_]}
	/varset parchLevelEnd ${SectionName.Arg[2,_]}
	/varset ribHave ${FindItemCount[=${SpellName}]}
	/varcalc ribNeed ${ribQty}-${ribHave}
	/if (${ribNeed} <= 0) {
		/echo Already have ${ribHave}/${ribQty} ${SpellName}, skipping.
		/continue
	}
	/echo === Import ${ribI}/${ribCount}: ${SpellName} x${ribNeed} (have ${ribHave}/${ribQty}) ===
	/varset singleSpellMode 1
	/varset singleSpellNum ${retrySpellNum}
	/varset singleSpellCopies ${ribNeed}
	/varset FailedSpells
	/varset FailCount 0
	/for ribCopy 1 to ${ribNeed}
		/call DoSpell ${retrySpellNum} ${SpellName}
	/next ribCopy
	/if (${FailCount} > 0) {
		/echo === Retrying ${FailCount} failed attempt(s) for ${SpellName} (max 3 passes) ===
		/call BuyForFailed
		/for ribRetryPass 1 to 3
			/if (${FailCount}==0) /break
			/varset FailCount 0
			/varset FailedSpells
			/call DoSpell ${retrySpellNum} ${SpellName}
		/next ribRetryPass
	}
	/varset ribHave ${FindItemCount[=${SpellName}]}
	/if (${ribHave} >= ${ribQty}) {
		/echo Verified ${SpellName}: have ${ribHave}/${ribQty}
	} else {
		/echo WARNING: ${SpellName} only ${ribHave}/${ribQty} after attempts.
	}
/next ribI

/call BankLeftoverDroppedParchments
/if (${clearTempOnEnd}) /call ClearBuyTempIni
:RibAbort
/varset importBatchMode 0
/varset singleSpellMode 0
/return

|-----------------------------------------------------------
| Parchment/Vellum type definitions
| Maps each parchment type to its solution, dropped ingredient,
| and vendor solution name
|-----------------------------------------------------------
| Types:
|   1 = Fine Runic Vellum    (solution: Fine Runic Vellum Solution,    dropped: Sooty Fine Runic Vellum)
|   2 = Fine Vellum          (solution: Fine Vellum Solution,          dropped: Grubby Fine Vellum)
|   3 = Vellum               (solution: Vellum Solution,               dropped: Dirty Vellum)
|   4 = Runic Vellum         (solution: Runic Vellum Solution,         dropped: Shabby Runic Vellum)
|   5 = Fine Runic Parchment (solution: Fine Runic Parchment Solution, dropped: Grimy Fine Runic Parchment)

|-----------------------------------------------------------
| Sub TallyParchmentNeeds — steps 1-6: count needs, validate drops
|-----------------------------------------------------------
Sub TallyParchmentNeeds
/declare cappLevel int local
/declare cappSection string local
/declare cappCount int local
/declare cappSpell int local
/declare cappIng int local
/declare cappIngName string local
/declare cappHave int local
/declare cappCopies int local

| Counters for each parchment type needed
/declare needFineRunicVellum int local 0
/declare needFineVellum int local 0
/declare needVellum int local 0
/declare needRunicVellum int local 0
/declare needFineRunicParchment int local 0

| Step 1: Count how many of each parchment type we need
/if (${importBatchMode}) {
	/declare ribTally int local
	/declare ribTallyCount int local ${Ini[ResearchLearn_pass.ini,Pass,Count]}
	/declare ribTallyItem string local
	/declare ribTallyQty int local
	/declare ribTallyHave int local
	/declare ribTallyNeed int local
	/declare ribTallySection string local
	/declare ribTallySpellNum int local
	/for ribTally 1 to ${ribTallyCount}
		/varset ribTallyItem ${Ini[ResearchLearn_pass.ini,Pass,Item${ribTally}]}
		/varset ribTallyQty ${Ini[ResearchLearn_pass.ini,Pass,Qty${ribTally}]}
		/if (${ribTallyQty} <= 0) /varset ribTallyQty 1
		/if (${ribTallyItem.Length}==0 || ${ribTallyItem.Equal[NULL]}) /continue
		/call FindSpellForImport ${ribTally} "${ribTallyItem}"
		/if (!${Macro.Return.Equal[TRUE]}) {
			/echo WARNING: Import batch — could not find "${ribTallyItem}" in ${rlIniFile}, skipping parchment tally.
			/continue
		}
		/varset ribTallySection ${SectionName}
		/varset ribTallySpellNum ${retrySpellNum}
		/varset ribTallyHave ${FindItemCount[=${SpellName}]}
		/varcalc ribTallyNeed ${ribTallyQty}-${ribTallyHave}
		/if (${ribTallyNeed} <= 0) /continue
		/for cappIng 1 to 20
			/varset cappIngName ${Ini[${rlIniFile},${ribTallySection},Spell${ribTallySpellNum}_Ingredient${cappIng}]}
			/if (${cappIngName.Length}==0 || ${cappIngName.Equal[NULL]}) /break
			/if (${cappIngName.Equal[Fine Runic Vellum]}) /varcalc needFineRunicVellum ${needFineRunicVellum}+${ribTallyNeed}
			/if (${cappIngName.Equal[Fine Vellum]}) /varcalc needFineVellum ${needFineVellum}+${ribTallyNeed}
			/if (${cappIngName.Equal[Vellum]}) /varcalc needVellum ${needVellum}+${ribTallyNeed}
			/if (${cappIngName.Equal[Runic Vellum]}) /varcalc needRunicVellum ${needRunicVellum}+${ribTallyNeed}
			/if (${cappIngName.Equal[Fine Runic Parchment]}) /varcalc needFineRunicParchment ${needFineRunicParchment}+${ribTallyNeed}
		/next cappIng
	/next ribTally
	/goto :CappLevelDone
}
/if (${singleSpellMode}) {
	/varset cappSection ${SectionName}
	/for cappIng 1 to 20
		/varset cappIngName ${Ini[${rlIniFile},${cappSection},Spell${singleSpellNum}_Ingredient${cappIng}]}
		/if (${cappIngName.Length}==0 || ${cappIngName.Equal[NULL]}) /break
		/if (${cappIngName.Equal[Fine Runic Vellum]}) /varcalc needFineRunicVellum ${needFineRunicVellum}+${singleSpellCopies}
		/if (${cappIngName.Equal[Fine Vellum]}) /varcalc needFineVellum ${needFineVellum}+${singleSpellCopies}
		/if (${cappIngName.Equal[Vellum]}) /varcalc needVellum ${needVellum}+${singleSpellCopies}
		/if (${cappIngName.Equal[Runic Vellum]}) /varcalc needRunicVellum ${needRunicVellum}+${singleSpellCopies}
		/if (${cappIngName.Equal[Fine Runic Parchment]}) /varcalc needFineRunicParchment ${needFineRunicParchment}+${singleSpellCopies}
	/next cappIng
	/goto :CappLevelDone
}
/varset cappLevel ${parchLevelStart}
:CappLevelLoop
	/if (${cappLevel} > ${parchLevelEnd}) /goto :CappLevelDone
	/varset cappSection ${ClassNameOuter}_${cappLevel}
	/varset cappCount ${Ini[${rlIniFile},${cappSection},SpellCount]}
	/if (${cappCount} > 0) {
		/for cappSpell 1 to ${cappCount}
			/varset cappHave ${FindItemCount[=${Ini[${rlIniFile},${cappSection},Spell${cappSpell}]}]}
			/varset cappCopies 0
			/varcalc cappCopies ${TargetQty}-${cappHave}
			/if (${cappCopies} <= 0) /continue
			/for cappIng 1 to 20
				/varset cappIngName ${Ini[${rlIniFile},${cappSection},Spell${cappSpell}_Ingredient${cappIng}]}
				/if (${cappIngName.Length}==0 || ${cappIngName.Equal[NULL]}) /break
				/if (${cappIngName.Equal[Fine Runic Vellum]}) /varcalc needFineRunicVellum ${needFineRunicVellum}+${cappCopies}
				/if (${cappIngName.Equal[Fine Vellum]}) /varcalc needFineVellum ${needFineVellum}+${cappCopies}
				/if (${cappIngName.Equal[Vellum]}) /varcalc needVellum ${needVellum}+${cappCopies}
				/if (${cappIngName.Equal[Runic Vellum]}) /varcalc needRunicVellum ${needRunicVellum}+${cappCopies}
				/if (${cappIngName.Equal[Fine Runic Parchment]}) /varcalc needFineRunicParchment ${needFineRunicParchment}+${cappCopies}
			/next cappIng
		/next cappSpell
	}
	/varcalc cappLevel ${cappLevel}+1
	/goto :CappLevelLoop
:CappLevelDone

/echo === Parchment needs: FineRunicVellum=${needFineRunicVellum} FineVellum=${needFineVellum} Vellum=${needVellum} RunicVellum=${needRunicVellum} FineRunicParchment=${needFineRunicParchment} ===

| Step 2: Subtract finished parchments already in inventory (include kit contents)
/call CountItemEverywhere "Fine Runic Vellum"
/varcalc needFineRunicVellum ${needFineRunicVellum}-${Macro.Return}
/call CountItemEverywhere "Fine Vellum"
/varcalc needFineVellum ${needFineVellum}-${Macro.Return}
/call CountItemEverywhere "Vellum"
/varcalc needVellum ${needVellum}-${Macro.Return}
/call CountItemEverywhere "Runic Vellum"
/varcalc needRunicVellum ${needRunicVellum}-${Macro.Return}
/call CountItemEverywhere "Fine Runic Parchment"
/varcalc needFineRunicParchment ${needFineRunicParchment}-${Macro.Return}
/if (${needFineRunicVellum} < 0) /varset needFineRunicVellum 0
/if (${needFineVellum} < 0) /varset needFineVellum 0
/if (${needVellum} < 0) /varset needVellum 0
/if (${needRunicVellum} < 0) /varset needRunicVellum 0
/if (${needFineRunicParchment} < 0) /varset needFineRunicParchment 0

/declare totalParchmentsNeeded int local 0
/varcalc totalParchmentsNeeded ${needFineRunicVellum}+${needFineVellum}+${needVellum}+${needRunicVellum}+${needFineRunicParchment}
/if (${totalParchmentsNeeded}==0) {
	/echo All parchments/vellums already in inventory!
	/varset parchVopwBatches 0
	/varset parchCleanserBatches 0
	/varset needKlazAfterParch 0
	/varset parchNeedFRV 0
	/varset parchNeedFV 0
	/varset parchNeedV 0
	/varset parchNeedRV 0
	/varset parchNeedFRP 0
	/return TRUE
}

| Step 3: Check how many dropped items we already have in inventory
/declare stillNeedSooty int local 0
/declare stillNeedGrubby int local 0
/declare stillNeedDirty int local 0
/declare stillNeedShabby int local 0
/declare stillNeedGrimy int local 0
/varcalc stillNeedSooty ${needFineRunicVellum}-${FindItemCount[=Sooty Fine Runic Vellum]}
/varcalc stillNeedGrubby ${needFineVellum}-${FindItemCount[=Grubby Fine Vellum]}
/varcalc stillNeedDirty ${needVellum}-${FindItemCount[=Dirty Vellum]}
/varcalc stillNeedShabby ${needRunicVellum}-${FindItemCount[=Shabby Runic Vellum]}
/varcalc stillNeedGrimy ${needFineRunicParchment}-${FindItemCount[=Grimy Fine Runic Parchment]}
/if (${stillNeedSooty} < 0) /varset stillNeedSooty 0
/if (${stillNeedGrubby} < 0) /varset stillNeedGrubby 0
/if (${stillNeedDirty} < 0) /varset stillNeedDirty 0
/if (${stillNeedShabby} < 0) /varset stillNeedShabby 0
/if (${stillNeedGrimy} < 0) /varset stillNeedGrimy 0

/declare missingDropped int local 0
/varcalc missingDropped ${stillNeedSooty}+${stillNeedGrubby}+${stillNeedDirty}+${stillNeedShabby}+${stillNeedGrimy}

| Step 4: dropped parchment must be in bags (bank trips disabled)
/if (${missingDropped} > 0) {
	/echo === MISSING DROPPED PARCHMENT INGREDIENTS - Cannot continue ===
	/if (${stillNeedSooty} > 0) /echo   Missing ${stillNeedSooty}x Sooty Fine Runic Vellum (needed for Fine Runic Vellum)
	/if (${stillNeedGrubby} > 0) /echo   Missing ${stillNeedGrubby}x Grubby Fine Vellum (needed for Fine Vellum)
	/if (${stillNeedDirty} > 0) /echo   Missing ${stillNeedDirty}x Dirty Vellum (needed for Vellum)
	/if (${stillNeedShabby} > 0) /echo   Missing ${stillNeedShabby}x Shabby Runic Vellum (needed for Runic Vellum)
	/if (${stillNeedGrimy} > 0) /echo   Missing ${stillNeedGrimy}x Grimy Fine Runic Parchment (needed for Fine Runic Parchment)
	/echo Please loot the missing items into your bags and try again.
	/return FALSE
}

| Step 5: Calculate Celestial Cleanser batches needed
/declare cleansersNeeded int local ${totalParchmentsNeeded}
/declare cleansersHave int local ${FindItemCount[=Celestial Cleanser]}
/declare cleansersStillNeeded int local 0
/varcalc cleansersStillNeeded ${cleansersNeeded}-${cleansersHave}
/if (${cleansersStillNeeded} < 0) /varset cleansersStillNeeded 0
/declare cleanserBatches int local 0
/varcalc cleanserBatches (${cleansersStillNeeded}+3)/4

| Step 6: Calculate Vials of Pure Water batches needed
/declare vopwNeeded int local 0
/varcalc vopwNeeded ${cleanserBatches}*3
/declare vopwHave int local ${FindItemCount[=Vial of Pure Water]}
/varcalc vopwNeeded ${vopwNeeded}-${vopwHave}
/if (${vopwNeeded} < 0) /varset vopwNeeded 0
/declare vopwBatches int local 0
/varcalc vopwBatches (${vopwNeeded}+4)/5

/echo === Need ${cleansersStillNeeded} Celestial Cleansers (${cleanserBatches} batches), ${vopwNeeded} Vials of Pure Water (${vopwBatches} batches) ===

| FIX: store batch counts in outer vars so ExecuteParchmentPrep/AddParchmentKlazToBuyList see them
/varset parchVopwBatches ${vopwBatches}
/varset parchCleanserBatches ${cleanserBatches}
/if (${vopwBatches} > 0 || ${cleanserBatches} > 0) /varset needKlazAfterParch 1

/varset parchNeedFRV ${needFineRunicVellum}
/varset parchNeedFV ${needFineVellum}
/varset parchNeedV ${needVellum}
/varset parchNeedRV ${needRunicVellum}
/varset parchNeedFRP ${needFineRunicParchment}
/return TRUE

Sub CheckAndPrepareParchments
/call TallyParchmentNeeds
/if (!${Macro.Return.Equal[TRUE]}) /return FALSE
/call ExecuteParchmentPrep
/return ${Macro.Return}

|-----------------------------------------------------------
| Sub ExecuteParchmentPrep — steps 7-11: vendors (Caden/Nursa), subcombines
| Requires TallyParchmentNeeds first; Klaz mats bought via NavAndBuy before this
|-----------------------------------------------------------
Sub ExecuteParchmentPrep
/declare vopwBatches int local ${parchVopwBatches}
/declare cleanserBatches int local ${parchCleanserBatches}
/declare needFineRunicVellum int local ${parchNeedFRV}
/declare needFineVellum int local ${parchNeedFV}
/declare needVellum int local ${parchNeedV}
/declare needRunicVellum int local ${parchNeedRV}
/declare needFineRunicParchment int local ${parchNeedFRP}
/declare totalParchmentsNeeded int local 0
/varcalc totalParchmentsNeeded ${needFineRunicVellum}+${needFineVellum}+${needVellum}+${needRunicVellum}+${needFineRunicParchment}
/if (${totalParchmentsNeeded}==0) /return TRUE

| Step 7: Buy Celestial Solvent from Caden
/if (${cleanserBatches} > 0) {
	/call NavAndBuyParchmentIngredients ${vopwBatches} ${cleanserBatches}
}

| Step 8: Buy solutions from Nursa Rasumus
/call NavAndBuySolutions ${needFineRunicVellum} ${needFineVellum} ${needVellum} ${needRunicVellum} ${needFineRunicParchment}

| Close vendor before opening research kit
/call CloseBlockingWindows

| Step 9: Open kit and make subcombines
/call RequireResearchKit

| Step 9a: Make Vials of Pure Water
/if (${vopwBatches} > 0) {
	/call MakeVialOfPureWater ${vopwBatches}
}

| Step 10: Make Celestial Cleansers
/if (${cleanserBatches} > 0) {
	/call MakeCelestialCleanser ${cleanserBatches}
}

| Step 11: Make parchments/vellums
/call MakeParchments ${needFineRunicVellum} ${needFineVellum} ${needVellum} ${needRunicVellum} ${needFineRunicParchment}

/echo === Parchment preparation complete ===
/return TRUE


|-----------------------------------------------------------
| Sub BankLeftoverDroppedParchments
| Banks any leftover dropped parchment ingredients after combines
|-----------------------------------------------------------
|-----------------------------------------------------------
| Sub BankLeftoverDroppedParchments
| Banks any leftover dropped parchment ingredients after combines
|-----------------------------------------------------------
Sub BankLeftoverDroppedParchments
| Bank trips disabled - leftover dropped parchments stay in bags
/return

| Legacy bank code (disabled)
Sub BankLeftoverDroppedParchments_DISABLED
/declare blpCount int local
/declare blpPack int local
/declare blpSlot int local
/declare blpMaxSlots int local
/declare blpSlotName string local
/declare blpBanked int local 0
/declare blpI int local

/varset blpI 1
:BlpCheckLoop
	/if (${blpI}==1) /varset blpItem Sooty Fine Runic Vellum
	/if (${blpI}==2) /varset blpItem Grubby Fine Vellum
	/if (${blpI}==3) /varset blpItem Dirty Vellum
	/if (${blpI}==4) /varset blpItem Shabby Runic Vellum
	/if (${blpI}==5) /varset blpItem Grimy Fine Runic Parchment
	/if (${blpI} > 5) /goto :BlpCheckDone
	/varset blpCount ${FindItemCount[=${blpItem}]}
	/if (${blpCount} > 0) /varcalc blpBanked ${blpBanked}+${blpCount}
	/varcalc blpI ${blpI}+1
	/goto :BlpCheckLoop
:BlpCheckDone

/if (${blpBanked}==0) /return

/echo Banking ${blpBanked} leftover dropped parchment item(s)...
/call NavTobanker
/if (!${Window[BigBankWnd].Open}) {
	/echo WARNING: Could not open bank to return leftover parchment items.
	/return
}

| Scan all bags for dropped items and bank them
/for blpPack 1 to 10
	/varset blpMaxSlots ${Me.Inventory[pack${blpPack}].Container}
	/if (${blpMaxSlots} == 0) /continue
	/for blpSlot 1 to ${blpMaxSlots}
		/varset blpSlotName ${Me.Inventory[pack${blpPack}].Item[${blpSlot}].Name}
		/if (${blpSlotName.Equal[Sooty Fine Runic Vellum]} || ${blpSlotName.Equal[Grubby Fine Vellum]} || ${blpSlotName.Equal[Dirty Vellum]} || ${blpSlotName.Equal[Shabby Runic Vellum]} || ${blpSlotName.Equal[Grimy Fine Runic Parchment]}) {
			/echo Banking ${blpSlotName}...
			/nomodkey /shift /itemnotify in pack${blpPack} ${blpSlot} leftmouseup
			/delay 10 ${Cursor.ID} || ${Window[QuantityWnd].Open}
			/if (${Window[QuantityWnd].Open}) {
				/notify QuantityWnd QTYW_Accept_Button leftmouseup
				/delay 5 !${Window[QuantityWnd].Open}
			}
			/if (!${Cursor.ID}) {
				/nomodkey /shift /itemnotify in pack${blpPack} ${blpSlot} leftmouseup
				/delay 10 ${Cursor.ID}
			}
			/if (${Cursor.ID}) {
				/notify BigBankWnd BIGB_AutoButton leftmouseup
				/delay 20 !${Cursor.ID} || ${Cursor.Name.Length}
				/if (${Cursor.ID}) /autoinv
				/delay 5 !${Cursor.ID}
			}
		}
	/next blpSlot
/next blpPack

/notify BigBankWnd DoneButton leftmouseup
/delay 10 !${Window[BigBankWnd].Open}
/echo Leftover parchment items banked.
| Reopen bags closed by bank window
/keypress b
/delay 10
/return


|-----------------------------------------------------------
| Sub CheckBankForDroppedParchments
| Opens bank and pulls dropped parchment ingredients we need
| Args are how many of each dropped item we still need
|-----------------------------------------------------------
Sub CheckBankForDroppedParchments(int needSooty, int needGrubby, int needDirty, int needShabby, int needGrimy)
| Bank trips disabled
/return

Sub CheckBankForDroppedParchments_DISABLED(int needSooty, int needGrubby, int needDirty, int needShabby, int needGrimy)
/declare cbfTotal int local 0
/varcalc cbfTotal ${needSooty}+${needGrubby}+${needDirty}+${needShabby}+${needGrimy}
/if (${cbfTotal}==0) /return

/echo Navigating to banker to pull dropped parchment ingredients...
/call NavTobanker
/if (!${Window[BigBankWnd].Open}) {
	/echo WARNING: Could not open bank - will check inventory only.
	/return
}

/if (${needSooty} > 0) /call PullFromBank "Sooty Fine Runic Vellum" ${needSooty}
/if (${needGrubby} > 0) /call PullFromBank "Grubby Fine Vellum" ${needGrubby}
/if (${needDirty} > 0) /call PullFromBank "Dirty Vellum" ${needDirty}
/if (${needShabby} > 0) /call PullFromBank "Shabby Runic Vellum" ${needShabby}
/if (${needGrimy} > 0) /call PullFromBank "Grimy Fine Runic Parchment" ${needGrimy}

/notify BigBankWnd DoneButton leftmouseup
/delay 10 !${Window[BigBankWnd].Open}
| Reopen bags closed by bank window
/keypress b
/delay 10
/return

|-----------------------------------------------------------
| Sub NavTobanker
| Navs to nearest banker and opens bank window
| (pattern from TurboGive's FindAndOpenBank)
|-----------------------------------------------------------
Sub NavTobanker
/if (${Window[BigBankWnd].Open}) /return

/if (${dropLevBeforeNav} && ${Me.Levitating}) {
	/removelev
	/delay 10 !${Me.Levitating}
}

/target clear
/delay 1

/if (${Target.ID} && ${Target.ID} != ${Me.ID} && ${Target.Type.NotEqual[PC]} && (${Target.Type.Equal[Banker]} || ${Target.Type.Equal[NPC]})) {
	/if (${Target.Distance} <= 10) {
		/face fast
		/delay 1
		/click right target
		/delay 100 ${Window[BigBankWnd].Open}
		/doevents
		/if (${Window[BigBankWnd].Open}) /return
	}
}

/target npc banker
/delay 5
/if (!${Target.ID} || ${Target.Type.Equal[PC]}) {
	/if (${SpawnCount[npc banker radius 200]} > 0) {
		/target npc banker radius 200
		/delay 5
	}
}
/if (!${Target.ID}) {
	/echo Could not find a banker!
	/return
}

/if (${Target.Distance} > 10) {
	/echo Navigating to banker (${Target.CleanName}, distance: ${Target.Distance})...
	/call NavToIDWithDoorsAndNudges ${Target.ID} 10 900
}

/face fast
/delay 1
/click right target
/delay 100 ${Window[BigBankWnd].Open}
/doevents
/if (!${Window[BigBankWnd].Open}) {
	/echo Could not open bank window!
}
/return

|-----------------------------------------------------------
| Sub PullFromBank
| Pulls up to needQty of itemName from bank into inventory
| Uses FindItemBank to locate the item then shift-clicks it
|-----------------------------------------------------------
|-----------------------------------------------------------
| Sub PullFromBank
| Pulls entire stack(s) of itemName from bank into inventory
| Scans bank slots 1-24 and bank bags, shift-clicks each stack
|-----------------------------------------------------------
|-----------------------------------------------------------
| Sub PullFromBank
| Pulls all stacks of itemName from bank into inventory
|-----------------------------------------------------------
|-----------------------------------------------------------
| Sub PullFromBank
| Pulls all stacks of itemName from bank into inventory
|-----------------------------------------------------------
Sub PullFromBank(string itemName, int needQty)
/declare pbSlot int local
/declare pbBagSlot int local
/declare pbMaxSlots int local
/declare pbName string local
/declare pbHaveNow int local

/if (!${Window[BigBankWnd].Open}) /return
/echo Checking bank for ${itemName} (need ${needQty})...

| Scan top-level bank slots using Me.Bank[] (TurboGive pattern)
/for pbSlot 1 to 24
	/varset pbHaveNow ${FindItemCount[=${itemName}]}
	/if (${pbHaveNow} >= ${needQty}) /goto :PbDone
	/if (!${Me.Bank[${pbSlot}].ID}) /continue
	/varset pbMaxSlots ${Me.Bank[${pbSlot}].Container}
	/if (${pbMaxSlots}) /continue
	| Direct item (not a bag)
	/varset pbName ${Me.Bank[${pbSlot}].Name}
	/if (!${pbName.Equal[${itemName}]}) /continue
	/echo Pulling ${pbName} from bank slot ${pbSlot}...
	/nomodkey /itemnotify bank${pbSlot} leftmouseup
	/delay 10 ${Cursor.ID} || ${Window[QuantityWnd].Open}
	/if (${Window[QuantityWnd].Open}) /call HandleQuantityWindow
	/delay 3 ${Cursor.ID}
	/if (${Cursor.ID}) {
		/autoinv
		/delay 10 !${Cursor.ID}
	}
/next pbSlot

| Scan inside bank bags using Me.Bank[] (TurboGive pattern)
/for pbSlot 1 to 24
	/varset pbHaveNow ${FindItemCount[=${itemName}]}
	/if (${pbHaveNow} >= ${needQty}) /goto :PbDone
	/if (!${Me.Bank[${pbSlot}].ID}) /continue
	/varset pbMaxSlots ${Me.Bank[${pbSlot}].Container}
	/if (!${pbMaxSlots}) /continue
	/for pbBagSlot 1 to ${pbMaxSlots}
		/varset pbHaveNow ${FindItemCount[=${itemName}]}
		/if (${pbHaveNow} >= ${needQty}) /goto :PbDone
		/if (!${Me.Bank[${pbSlot}].Item[${pbBagSlot}].ID}) /continue
		/varset pbName ${Me.Bank[${pbSlot}].Item[${pbBagSlot}].Name}
		/if (!${pbName.Equal[${itemName}]}) /continue
		/echo Pulling ${pbName} from bank bag ${pbSlot} slot ${pbBagSlot}...
		/nomodkey /itemnotify in bank${pbSlot} ${pbBagSlot} leftmouseup
		/delay 10 ${Cursor.ID} || ${Window[QuantityWnd].Open}
		/if (${Window[QuantityWnd].Open}) {
			/notify QuantityWnd QTYW_Accept_Button leftmouseup
			/delay 5 !${Window[QuantityWnd].Open}
			/if (${Window[QuantityWnd].Open}) {
				/keypress ENTER
				/delay 5 !${Window[QuantityWnd].Open}
			}
		}
		/delay 3 ${Cursor.ID}
		/if (${Cursor.ID}) {
			/autoinv
			/delay 10 !${Cursor.ID}
		}
	/next pbBagSlot
/next pbSlot

:PbDone
/echo ${itemName}: now have ${FindItemCount[=${itemName}]}x in inventory (needed ${needQty}).
/return


|-----------------------------------------------------------
| Sub NavAndBuyParchmentIngredients
| Buys VoPW and Cleanser ingredients from Scholar Klaz and
| Celestial Solvent from Caden Zharik
|-----------------------------------------------------------
Sub NavAndBuyParchmentIngredients(int vopwBatches, int cleanserBatches)
/declare nabpiBuyQty int local

| Klaz vials/flasks are bought in the merged Scholar Klaz pass (AddParchmentKlazToBuyList)

| Nav to Caden Zharik for Celestial Solvent: 1 per Cleanser batch
/if (${cleanserBatches} > 0) {
	/varset nabpiBuyQty ${cleanserBatches}
	/varcalc nabpiBuyQty ${nabpiBuyQty}-${FindItemCount[=Celestial Solvent]}
	/if (${nabpiBuyQty} > 0) {
		/echo Navigating to Caden Zharik for Celestial Solvent...
		/call NavToSpawn "Caden Zharik"
		/if (!${Macro.Return.Equal[TRUE]}) /return
		/call OpenTargetMerchant
		/if (!${Macro.Return.Equal[TRUE]}) /return
		/call BuyFromMerchant "Celestial Solvent" ${nabpiBuyQty}
		/notify MerchantWnd MW_Done_Button leftmouseup
		/delay 10
	}
}
/return

|-----------------------------------------------------------
| Sub NavAndBuySolutions
| Buys the correct solutions from Nursa Rasumus
|-----------------------------------------------------------
Sub NavAndBuySolutions(int needFRV, int needFV, int needV, int needRV, int needFRP)
/declare nabsTotalSolutions int local 0
/varcalc nabsTotalSolutions ${needFRV}+${needFV}+${needV}+${needRV}+${needFRP}
/if (${nabsTotalSolutions}==0) /return

/declare nabsBuyQty int local

/echo Navigating to Nursa Rasumus for parchment solutions...
/call NavToSpawn "Nursa Rasumus"
/if (!${Macro.Return.Equal[TRUE]}) /return
/call OpenTargetMerchant
/if (!${Macro.Return.Equal[TRUE]}) /return

/if (${needFRV} > 0) {
	/varset nabsBuyQty ${needFRV}
	/varcalc nabsBuyQty ${nabsBuyQty}-${FindItemCount[=Fine Runic Vellum Solution]}
	/if (${nabsBuyQty} > 0) /call BuyFromMerchant "Fine Runic Vellum Solution" ${nabsBuyQty}
}
/if (${needFV} > 0) {
	/varset nabsBuyQty ${needFV}
	/varcalc nabsBuyQty ${nabsBuyQty}-${FindItemCount[=Fine Vellum Solution]}
	/if (${nabsBuyQty} > 0) /call BuyFromMerchant "Fine Vellum Solution" ${nabsBuyQty}
}
/if (${needV} > 0) {
	/varset nabsBuyQty ${needV}
	/varcalc nabsBuyQty ${nabsBuyQty}-${FindItemCount[=Vellum Solution]}
	/if (${nabsBuyQty} > 0) /call BuyFromMerchant "Vellum Solution" ${nabsBuyQty}
}
/if (${needRV} > 0) {
	/varset nabsBuyQty ${needRV}
	/varcalc nabsBuyQty ${nabsBuyQty}-${FindItemCount[=Runic Vellum Solution]}
	/if (${nabsBuyQty} > 0) /call BuyFromMerchant "Runic Vellum Solution" ${nabsBuyQty}
}
/if (${needFRP} > 0) {
	/varset nabsBuyQty ${needFRP}
	/varcalc nabsBuyQty ${nabsBuyQty}-${FindItemCount[=Fine Runic Parchment Solution]}
	/if (${nabsBuyQty} > 0) /call BuyFromMerchant "Fine Runic Parchment Solution" ${nabsBuyQty}
}

/notify MerchantWnd MW_Done_Button leftmouseup
/delay 10
/return

|-----------------------------------------------------------
| Sub BuyFromMerchant
| Buys qty of itemName from currently open merchant window
|-----------------------------------------------------------
Sub BuyFromMerchant(string itemName, int qty)
/call BuyItemFromMerchant "${itemName}" ${qty}
/return

|-----------------------------------------------------------
| Sub MakeVialOfPureWater
| Does vopwBatches combines of Vial of Pure Water
| Recipe: 5x Empty Vial + 1x Gnomish Heat Source + 4x Water Flask -> 5x Vial of Pure Water
|-----------------------------------------------------------
Sub MakeVialOfPureWater(int vopwBatches)
/declare mvpwBatch int local
/declare mvpwSlot int local
/declare mvpwI int local

/echo === Making ${vopwBatches} batch(es) of Vial of Pure Water ===

/for mvpwBatch 1 to ${vopwBatches}
	/echo Vial of Pure Water batch ${mvpwBatch}/${vopwBatches}...

	/call ClearResearchKit

	/for mvpwI 1 to 5
		/call QuickGrabDrop "Empty Vial" ${mvpwI}
	/next mvpwI

	/call QuickGrabDrop "Gnomish Heat Source" 6

	/for mvpwI 1 to 4
		/varcalc mvpwSlot 6+${mvpwI}
		/call QuickGrabDrop "Water Flask" ${mvpwSlot}
	/next mvpwI

	/call DoCombineAndVerify "Vial of Pure Water"
	/if (!${Macro.Return.Equal[TRUE]}) {
		/echo WARNING: Vial of Pure Water batch ${mvpwBatch} failed - clearing kit and continuing.
	}
/next mvpwBatch
/echo === Vial of Pure Water combines done ===
/return

|-----------------------------------------------------------
| Sub MakeCelestialCleanser
| Does cleanserBatches combines of Celestial Cleanser
| Recipe: 1x Celestial Solvent + 1x Empty Vial + 3x Vial of Pure Water -> 4x Celestial Cleanser
|-----------------------------------------------------------
Sub MakeCelestialCleanser(int cleanserBatches)
/declare mccBatch int local
/declare mccSlot int local
/declare mccI int local

/echo === Making ${cleanserBatches} batch(es) of Celestial Cleanser ===

/for mccBatch 1 to ${cleanserBatches}
	/echo Celestial Cleanser batch ${mccBatch}/${cleanserBatches}...

	/call ClearResearchKit

	/call QuickGrabDrop "Celestial Solvent" 1
	/call QuickGrabDrop "Empty Vial" 2

	/for mccI 1 to 3
		/varcalc mccSlot 2+${mccI}
		/call QuickGrabDrop "Vial of Pure Water" ${mccSlot}
	/next mccI

	/call DoCombineAndVerify "Celestial Cleanser"
	/if (!${Macro.Return.Equal[TRUE]}) {
		/echo WARNING: Celestial Cleanser batch ${mccBatch} failed - clearing kit and continuing.
	}
/next mccBatch
/echo === Celestial Cleanser combines done ===
/return

|-----------------------------------------------------------
| Sub MakeParchments
| Makes all needed parchments/vellums
| Each recipe: 1x Celestial Cleanser + 1x Solution + 1x Dropped Item -> 1x Parchment
|-----------------------------------------------------------
Sub MakeParchments(int needFRV, int needFV, int needV, int needRV, int needFRP)
/declare mpStillNeed int local
/declare mpHave int local
/declare mpHaveBaseline int local
/declare mpCrafted int local
/declare mpAttempts int local
/declare mpMaxAttempts int local 5
/declare mpCombineTries int local
/declare mpCombineMax int local

/echo === Making parchments/vellums ===
/call EnsureResearchKitOpen
/if (!${Macro.Return.Equal[TRUE]}) {
	/call RequireResearchKit
}

| Each type: loop until crafted count reaches need, replenishing on failure
| Fine Runic Vellum
/if (${needFRV} > 0) {
	/call CountItemEverywhere "Fine Runic Vellum"
	/varset mpHaveBaseline ${Macro.Return}
	/varset mpAttempts 0
	:MpFRVLoop
		/call CountItemEverywhere "Fine Runic Vellum"
		/varset mpHave ${Macro.Return}
		/varcalc mpCrafted ${mpHave}-${mpHaveBaseline}
		/varcalc mpStillNeed ${needFRV}-${mpCrafted}
		/if (${mpStillNeed} <= 0) /goto :MpFRVDone
		/if (${mpAttempts} >= ${mpMaxAttempts}) {
			/echo ERROR: Failed to make Fine Runic Vellum after ${mpMaxAttempts} attempts - missing ingredients?
			/goto :MpFRVDone
		}
		/varcalc mpAttempts ${mpAttempts}+1
		/echo Making Fine Runic Vellum (crafted ${mpCrafted}/${needFRV}, attempt ${mpAttempts})...
		/call ReplenishParchmentIngredients "Fine Runic Vellum Solution" "Sooty Fine Runic Vellum" "Celestial Cleanser" ${mpStillNeed}
		/varset mpCombineTries 0
		/varcalc mpCombineMax ${needFRV}*2+3
		:MpFRVCombineLoop
			/call CountItemEverywhere "Fine Runic Vellum"
			/varset mpHave ${Macro.Return}
			/varcalc mpCrafted ${mpHave}-${mpHaveBaseline}
			/varcalc mpStillNeed ${needFRV}-${mpCrafted}
			/if (${mpStillNeed} <= 0) /goto :MpFRVDone
			/varcalc mpCombineTries ${mpCombineTries}+1
			/if (${mpCombineTries} > ${mpCombineMax}) {
				/echo ERROR: Fine Runic Vellum combine loop exceeded ${mpCombineMax} tries (crafted ${mpCrafted}/${needFRV}) - stopping.
				/goto :MpFRVDone
			}
			/if (!${FindItemCount[=Celestial Cleanser]} || !${FindItemCount[=Fine Runic Vellum Solution]} || !${FindItemCount[=Sooty Fine Runic Vellum]}) /goto :MpFRVLoop
			/call MakeOneParchment "Fine Runic Vellum Solution" "Sooty Fine Runic Vellum" "Fine Runic Vellum"
			/goto :MpFRVCombineLoop
	:MpFRVDone
}

| Fine Vellum
/if (${needFV} > 0) {
	/call CountItemEverywhere "Fine Vellum"
	/varset mpHaveBaseline ${Macro.Return}
	/varset mpAttempts 0
	:MpFVLoop
		/call CountItemEverywhere "Fine Vellum"
		/varset mpHave ${Macro.Return}
		/varcalc mpCrafted ${mpHave}-${mpHaveBaseline}
		/varcalc mpStillNeed ${needFV}-${mpCrafted}
		/if (${mpStillNeed} <= 0) /goto :MpFVDone
		/if (${mpAttempts} >= ${mpMaxAttempts}) {
			/echo ERROR: Failed to make Fine Vellum after ${mpMaxAttempts} attempts - missing ingredients?
			/goto :MpFVDone
		}
		/varcalc mpAttempts ${mpAttempts}+1
		/echo Making Fine Vellum (crafted ${mpCrafted}/${needFV}, attempt ${mpAttempts})...
		/call ReplenishParchmentIngredients "Fine Vellum Solution" "Grubby Fine Vellum" "Celestial Cleanser" ${mpStillNeed}
		/varset mpCombineTries 0
		/varcalc mpCombineMax ${needFV}*2+3
		:MpFVCombineLoop
			/call CountItemEverywhere "Fine Vellum"
			/varset mpHave ${Macro.Return}
			/varcalc mpCrafted ${mpHave}-${mpHaveBaseline}
			/varcalc mpStillNeed ${needFV}-${mpCrafted}
			/if (${mpStillNeed} <= 0) /goto :MpFVDone
			/varcalc mpCombineTries ${mpCombineTries}+1
			/if (${mpCombineTries} > ${mpCombineMax}) {
				/echo ERROR: Fine Vellum combine loop exceeded ${mpCombineMax} tries (crafted ${mpCrafted}/${needFV}) - stopping.
				/goto :MpFVDone
			}
			/if (!${FindItemCount[=Celestial Cleanser]} || !${FindItemCount[=Fine Vellum Solution]} || !${FindItemCount[=Grubby Fine Vellum]}) /goto :MpFVLoop
			/call MakeOneParchment "Fine Vellum Solution" "Grubby Fine Vellum" "Fine Vellum"
			/goto :MpFVCombineLoop
	:MpFVDone
}

| Vellum
/if (${needV} > 0) {
	/call CountItemEverywhere "Vellum"
	/varset mpHaveBaseline ${Macro.Return}
	/varset mpAttempts 0
	:MpVLoop
		/call CountItemEverywhere "Vellum"
		/varset mpHave ${Macro.Return}
		/varcalc mpCrafted ${mpHave}-${mpHaveBaseline}
		/varcalc mpStillNeed ${needV}-${mpCrafted}
		/if (${mpStillNeed} <= 0) /goto :MpVDone
		/if (${mpAttempts} >= ${mpMaxAttempts}) {
			/echo ERROR: Failed to make Vellum after ${mpMaxAttempts} attempts - missing ingredients?
			/goto :MpVDone
		}
		/varcalc mpAttempts ${mpAttempts}+1
		/echo Making Vellum (crafted ${mpCrafted}/${needV}, attempt ${mpAttempts})...
		/call ReplenishParchmentIngredients "Vellum Solution" "Dirty Vellum" "Celestial Cleanser" ${mpStillNeed}
		/varset mpCombineTries 0
		/varcalc mpCombineMax ${needV}*2+3
		:MpVCombineLoop
			/call CountItemEverywhere "Vellum"
			/varset mpHave ${Macro.Return}
			/varcalc mpCrafted ${mpHave}-${mpHaveBaseline}
			/varcalc mpStillNeed ${needV}-${mpCrafted}
			/if (${mpStillNeed} <= 0) /goto :MpVDone
			/varcalc mpCombineTries ${mpCombineTries}+1
			/if (${mpCombineTries} > ${mpCombineMax}) {
				/echo ERROR: Vellum combine loop exceeded ${mpCombineMax} tries (crafted ${mpCrafted}/${needV}) - stopping.
				/goto :MpVDone
			}
			/if (!${FindItemCount[=Celestial Cleanser]} || !${FindItemCount[=Vellum Solution]} || !${FindItemCount[=Dirty Vellum]}) /goto :MpVLoop
			/call MakeOneParchment "Vellum Solution" "Dirty Vellum" "Vellum"
			/goto :MpVCombineLoop
	:MpVDone
}

| Runic Vellum
/if (${needRV} > 0) {
	/call CountItemEverywhere "Runic Vellum"
	/varset mpHaveBaseline ${Macro.Return}
	/varset mpAttempts 0
	:MpRVLoop
		/call CountItemEverywhere "Runic Vellum"
		/varset mpHave ${Macro.Return}
		/varcalc mpCrafted ${mpHave}-${mpHaveBaseline}
		/varcalc mpStillNeed ${needRV}-${mpCrafted}
		/if (${mpStillNeed} <= 0) /goto :MpRVDone
		/if (${mpAttempts} >= ${mpMaxAttempts}) {
			/echo ERROR: Failed to make Runic Vellum after ${mpMaxAttempts} attempts - missing ingredients?
			/goto :MpRVDone
		}
		/varcalc mpAttempts ${mpAttempts}+1
		/echo Making Runic Vellum (crafted ${mpCrafted}/${needRV}, attempt ${mpAttempts})...
		/call ReplenishParchmentIngredients "Runic Vellum Solution" "Shabby Runic Vellum" "Celestial Cleanser" ${mpStillNeed}
		/varset mpCombineTries 0
		/varcalc mpCombineMax ${needRV}*2+3
		:MpRVCombineLoop
			/call CountItemEverywhere "Runic Vellum"
			/varset mpHave ${Macro.Return}
			/varcalc mpCrafted ${mpHave}-${mpHaveBaseline}
			/varcalc mpStillNeed ${needRV}-${mpCrafted}
			/if (${mpStillNeed} <= 0) /goto :MpRVDone
			/varcalc mpCombineTries ${mpCombineTries}+1
			/if (${mpCombineTries} > ${mpCombineMax}) {
				/echo ERROR: Runic Vellum combine loop exceeded ${mpCombineMax} tries (crafted ${mpCrafted}/${needRV}) - stopping.
				/goto :MpRVDone
			}
			/if (!${FindItemCount[=Celestial Cleanser]} || !${FindItemCount[=Runic Vellum Solution]} || !${FindItemCount[=Shabby Runic Vellum]}) /goto :MpRVLoop
			/call MakeOneParchment "Runic Vellum Solution" "Shabby Runic Vellum" "Runic Vellum"
			/goto :MpRVCombineLoop
	:MpRVDone
}

| Fine Runic Parchment
/if (${needFRP} > 0) {
	/call CountItemEverywhere "Fine Runic Parchment"
	/varset mpHaveBaseline ${Macro.Return}
	/varset mpAttempts 0
	:MpFRPLoop
		/call CountItemEverywhere "Fine Runic Parchment"
		/varset mpHave ${Macro.Return}
		/varcalc mpCrafted ${mpHave}-${mpHaveBaseline}
		/varcalc mpStillNeed ${needFRP}-${mpCrafted}
		/if (${mpStillNeed} <= 0) /goto :MpFRPDone
		/if (${mpAttempts} >= ${mpMaxAttempts}) {
			/echo ERROR: Failed to make Fine Runic Parchment after ${mpMaxAttempts} attempts - missing ingredients?
			/goto :MpFRPDone
		}
		/varcalc mpAttempts ${mpAttempts}+1
		/echo Making Fine Runic Parchment (crafted ${mpCrafted}/${needFRP}, attempt ${mpAttempts})...
		/call ReplenishParchmentIngredients "Fine Runic Parchment Solution" "Grimy Fine Runic Parchment" "Celestial Cleanser" ${mpStillNeed}
		/varset mpCombineTries 0
		/varcalc mpCombineMax ${needFRP}*2+3
		:MpFRPCombineLoop
			/call CountItemEverywhere "Fine Runic Parchment"
			/varset mpHave ${Macro.Return}
			/varcalc mpCrafted ${mpHave}-${mpHaveBaseline}
			/varcalc mpStillNeed ${needFRP}-${mpCrafted}
			/if (${mpStillNeed} <= 0) /goto :MpFRPDone
			/varcalc mpCombineTries ${mpCombineTries}+1
			/if (${mpCombineTries} > ${mpCombineMax}) {
				/echo ERROR: Fine Runic Parchment combine loop exceeded ${mpCombineMax} tries (crafted ${mpCrafted}/${needFRP}) - stopping.
				/goto :MpFRPDone
			}
			/if (!${FindItemCount[=Celestial Cleanser]} || !${FindItemCount[=Fine Runic Parchment Solution]} || !${FindItemCount[=Grimy Fine Runic Parchment]}) /goto :MpFRPLoop
			/call MakeOneParchment "Fine Runic Parchment Solution" "Grimy Fine Runic Parchment" "Fine Runic Parchment"
			/goto :MpFRPCombineLoop
	:MpFRPDone
	/call ClearResearchKit
}

/echo === Parchment combines done ===
/return

|-----------------------------------------------------------
| Sub ReplenishParchmentIngredients
| Called when a parchment combine fails or we run short.
| Checks what's missing for needQty more combines and restocks:
|   - Celestial Cleanser (and its sub-ingredients) from vendors
|   - solution from Nursa Rasumus
|   - dropped item from bank
| Args: solutionName, droppedItem, cleanserName, needQty
|-----------------------------------------------------------
Sub ReplenishParchmentIngredients(string solutionName, string droppedItem, string cleanserName, int needQty)
/declare rpiNeedCleanser int local
/declare rpiNeedSolution int local
/declare rpiNeedDropped int local
/declare rpiCleanserBatches int local
/declare rpiVopwNeeded int local
/declare rpiVopwHave int local
/declare rpiVopwBatches int local

| How many of each ingredient are we short?
/varcalc rpiNeedCleanser ${needQty}-${FindItemCount[=${cleanserName}]}
/varcalc rpiNeedSolution ${needQty}-${FindItemCount[=${solutionName}]}
/varcalc rpiNeedDropped ${needQty}-${FindItemCount[=${droppedItem}]}
/if (${rpiNeedCleanser} < 0) /varset rpiNeedCleanser 0
/if (${rpiNeedSolution} < 0) /varset rpiNeedSolution 0
/if (${rpiNeedDropped} < 0) /varset rpiNeedDropped 0

/if (${rpiNeedCleanser}==0 && ${rpiNeedSolution}==0 && ${rpiNeedDropped}==0) /return

/echo === Replenishing parchment ingredients (need ${needQty}x more) ===

| Dropped items must already be in bags (bank disabled)
/if (${rpiNeedDropped} > 0) {
	/echo NOTE: Need ${rpiNeedDropped}x ${droppedItem} in inventory - bank pull is disabled.
}

| Solution comes from Nursa Rasumus — reuse NavAndBuySolutions which has the correct
| nav pattern and /delay 20 after open that the vendor item list needs to load
/if (${rpiNeedSolution} > 0) {
	/echo Buying ${rpiNeedSolution}x ${solutionName} from Nursa Rasumus...
	/declare rpiNeedFRV int local 0
	/declare rpiNeedFV int local 0
	/declare rpiNeedV int local 0
	/declare rpiNeedRV int local 0
	/declare rpiNeedFRP int local 0
	/if (${solutionName.Equal[Fine Runic Vellum Solution]}) /varset rpiNeedFRV ${rpiNeedSolution}
	/if (${solutionName.Equal[Fine Vellum Solution]}) /varset rpiNeedFV ${rpiNeedSolution}
	/if (${solutionName.Equal[Vellum Solution]}) /varset rpiNeedV ${rpiNeedSolution}
	/if (${solutionName.Equal[Runic Vellum Solution]}) /varset rpiNeedRV ${rpiNeedSolution}
	/if (${solutionName.Equal[Fine Runic Parchment Solution]}) /varset rpiNeedFRP ${rpiNeedSolution}
	/call NavAndBuySolutions ${rpiNeedFRV} ${rpiNeedFV} ${rpiNeedV} ${rpiNeedRV} ${rpiNeedFRP}
}

| Celestial Cleanser: need to make more batches (4 per batch)
/if (${rpiNeedCleanser} > 0) {
	/varcalc rpiCleanserBatches (${rpiNeedCleanser}+3)/4
	| Check VoPW supply (3 per cleanser batch)
	/varcalc rpiVopwNeeded ${rpiCleanserBatches}*3
	/varcalc rpiVopwHave ${FindItemCount[=Vial of Pure Water]}
	/varcalc rpiVopwNeeded ${rpiVopwNeeded}-${rpiVopwHave}
	/if (${rpiVopwNeeded} < 0) /varset rpiVopwNeeded 0
	/varcalc rpiVopwBatches (${rpiVopwNeeded}+4)/5
	/echo Need ${rpiNeedCleanser} more Celestial Cleansers (${rpiCleanserBatches} batches)...
	/call NavAndBuyParchmentIngredients ${rpiVopwBatches} ${rpiCleanserBatches}
	/if (${rpiVopwBatches} > 0) {
		/call MakeVialOfPureWater ${rpiVopwBatches}
	}
	/call MakeCelestialCleanser ${rpiCleanserBatches}
}
/return

|-----------------------------------------------------------
| Sub MakeOneParchment
| Does a single parchment combine
| Args: solutionName, droppedItem, resultName
|-----------------------------------------------------------
Sub MakeOneParchment(string solutionName, string droppedItem, string resultName)
/declare mopSlot int local

/call GuardResearchKit

| Check we have all ingredients
/if (!${FindItemCount[=Celestial Cleanser]}) {
	/echo WARNING: Out of Celestial Cleansers! Cannot make ${resultName}.
	/return
}
/if (!${FindItemCount[=${solutionName}]}) {
	/echo WARNING: Missing ${solutionName}! Cannot make ${resultName}.
	/return
}
/if (!${FindItemCount[=${droppedItem}]}) {
	/echo WARNING: Missing ${droppedItem}! Cannot make ${resultName}.
	/return
}

/call ClearResearchKit

/call QuickGrabDrop "Celestial Cleanser" 1
/call QuickGrabDrop "${solutionName}" 2
/call QuickGrabDrop "${droppedItem}" 3

/call DoCombineAndVerify "${resultName}"
/if (${Macro.Return.Equal[TRUE]}) {
	/echo Made ${resultName}!
} else {
	/echo WARNING: ${resultName} combine failed.
}
/return

|-----------------------------------------------------------
| Sub DoCombineAndVerify
| Fires the combine, waits up to 2s for result on cursor,
| clears the kit if nothing landed, returns 1 on success
|-----------------------------------------------------------
Sub DoCombineAndVerify(string expectedResult)
/declare dcvWait int local 0
/declare dcvHaveBefore int local 0
/declare dcvHaveAfter int local 0

/call GuardResearchKit
/call CountItemEverywhere "${expectedResult}"
/varset dcvHaveBefore ${Macro.Return}

/varset combineSucceeded FALSE
/varset combineFailed FALSE
/call DoKitCombine
:DcvWaitLoop
	/delay 3
	/doevents
	/if (${combineSucceeded} || ${Cursor.ID}) /goto :DcvWaitDone
	/if (${combineFailed}) /goto :DcvFailDone
	/call CountItemEverywhere "${expectedResult}"
	/if (${Macro.Return} > ${dcvHaveBefore}) /goto :DcvSuccessDone
	/varcalc dcvWait ${dcvWait}+1
	/if (${dcvWait} < 8) /goto :DcvWaitLoop
:DcvWaitDone
/doevents

/if (${combineFailed}) /goto :DcvFailDone
/call CountItemEverywhere "${expectedResult}"
/varset dcvHaveAfter ${Macro.Return}
/if (${dcvHaveAfter} > ${dcvHaveBefore}) /goto :DcvSuccessDone
/if (${Cursor.ID}) {
	/if (${Cursor.Name.Equal[${expectedResult}]} || ${Cursor.Name.Find[${expectedResult}]}) {
		/autoinv
		/call WaitForEmptyCursor 250
		/call ClearResearchKit
		/return TRUE
	}
}
/if (${combineSucceeded}) {
	/call ClearResearchKit
	/delay 5
	/call CountItemEverywhere "${expectedResult}"
	/if (${Macro.Return} > ${dcvHaveBefore}) /goto :DcvSuccessDone
}

:DcvFailDone
/if (${Cursor.ID}) /call ForceClearCursor
/call ClearResearchKit
/return FALSE

:DcvSuccessDone
/call ClearResearchKit
/call WaitForEmptyCursor 250
/return TRUE
